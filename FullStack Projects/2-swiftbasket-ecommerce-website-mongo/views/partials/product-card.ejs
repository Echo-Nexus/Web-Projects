<div
  class="group bg-white dark:bg-gray-900 rounded-3xl overflow-hidden border border-gray-200 dark:border-gray-800 shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
  <!-- Product Image -->
  <div class="relative overflow-hidden">
    <img src="<%= product.image %>" alt="<%= product.title %>"
      class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110" />

    <!-- Badge -->
    <% if(product.badge) { %>
      <span class="absolute top-4 left-4 px-3 py-1 text-xs font-bold rounded-full bg-red-500 text-white shadow-lg">
        <%= product.badge %>
      </span>
      <% } %>

        <!-- Rating -->
        <div
          class="absolute top-4 right-4 flex items-center gap-1 px-2 py-1 rounded-full bg-white/90 dark:bg-gray-800/90 backdrop-blur">
          <i data-lucide="star" class="w-4 h-4 text-yellow-500 fill-yellow-500"></i>
          <span class="text-sm font-semibold">
            <%= product.rating %>
          </span>
        </div>
  </div>

  <!-- Content -->
  <div class="p-5">

    <!-- Category -->
    <div class="mb-2">
      <span
        class="inline-block px-3 py-1 text-xs font-semibold rounded-full bg-sky-100 text-sky-700 dark:bg-sky-900/40 dark:text-sky-300">
        <%= product.category %>
      </span>
    </div>

    <!-- Title -->
    <h3 class="text-lg font-bold text-gray-900 dark:text-white line-clamp-2 min-h-[56px]">
      <%= product.title %>
    </h3>

    <!-- Description -->
    <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 line-clamp-2">
      <%= product.description %>
    </p>

    <!-- Location -->
    <div class="flex items-center gap-2 mt-4 text-sm text-gray-500 dark:text-gray-400">
      <i data-lucide="map-pin" class="w-4 h-4"></i>
      <span>
        <%= product.location %>
      </span>
    </div>

    <!-- Reviews -->
    <div class="flex items-center gap-2 mt-2 text-sm text-gray-500 dark:text-gray-400">
      <i data-lucide="message-circle" class="w-4 h-4"></i>
      <span>
        <%= product.reviews %> reviews
      </span>
    </div>

    <!-- Bottom Section -->
    <div class="flex items-center justify-between mt-6 pt-4 border-t border-gray-200 dark:border-gray-800">
      <div>
        <p class="text-xs text-gray-500 dark:text-gray-400">
          Price
        </p>

        <h4 class="text-2xl font-extrabold text-sky-600 dark:text-sky-400">
          $<%= product.price %>
        </h4>
      </div>

      <a href="/store/products/details/<%= product.id %>"
        class="group/btn inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-sky-600 hover:bg-sky-700 text-white font-semibold transition-all duration-300">
        View

        <i data-lucide="arrow-right"
          class="w-4 h-4 transition-transform duration-300 group-hover/btn:translate-x-1"></i>
      </a>
    </div>
  </div>
</div>