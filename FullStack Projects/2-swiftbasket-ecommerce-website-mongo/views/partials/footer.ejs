<!-- PREMIUM E-COMMERCE FOOTER - SWIFT BASKET -->

<footer
  class="border-t border-gray-100 dark:border-zinc-800 bg-gray-50 dark:bg-zinc-900/50 mt-16 py-12 sm:py-16 transition-colors duration-300">
  <hr class="border-gray-200 dark:border-zinc-800 my-8" />
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <!-- GRID -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-12 mb-12">
      <!-- COLUMN 1: BRAND -->
      <div class="space-y-4">
        <!-- LOGO -->
        <a href="/" class="flex items-center gap-2 group select-none">
          <svg class="h-7 w-7 text-sky-500 group-hover:text-sky-400 transition" viewBox="0 0 100 100" fill="none">
            <!-- Cart -->
            <path d="M20 25 H30 L38 65 H75" stroke="currentColor" stroke-width="10" stroke-linecap="round"
              stroke-linejoin="round" />

            <!-- Wheels -->
            <circle cx="45" cy="75" r="6" fill="currentColor" />
            <circle cx="68" cy="75" r="6" fill="currentColor" />

            <!-- Growth Arrow -->
            <path d="M55 15 L55 45 M45 25 L55 15 L65 25" stroke="currentColor" stroke-width="8" stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>

          <span class="font-extrabold text-xl tracking-tight text-zinc-900 dark:text-white">
            Swift Basket
          </span>
        </a>

        <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
          Fast, reliable, and seamless shopping experience. Discover
          thousands of products with lightning-speed checkout and curated
          deals made just for you.
        </p>
      </div>

      <!-- COLUMN 2: SHOP -->
      <div class="space-y-3.5">
        <h4 class="text-xs font-black uppercase tracking-widest text-zinc-900 dark:text-white">
          Shop
        </h4>

        <ul class="space-y-2 text-sm">
          <li>
            <a href="/store/products" class="text-gray-500 hover:text-sky-500 transition">All Products</a>
          </li>
          <li>
            <a href="/store/deals" class="text-gray-500 hover:text-sky-500 transition">Hot Deals</a>
          </li>
          <li>
            <a href="/store/categories" class="text-gray-500 hover:text-sky-500 transition">Categories</a>
          </li>
          <li>
            <a href="/store/new-arrivals" class="text-gray-500 hover:text-sky-500 transition">New Arrivals</a>
          </li>
        </ul>
      </div>

      <!-- COLUMN 3: ACCOUNT -->
      <div class="space-y-3.5">
        <h4 class="text-xs font-black uppercase tracking-widest text-zinc-900 dark:text-white">
          Account
        </h4>

        <ul class="space-y-2 text-sm">
          <li>
            <a href="/user/orders" class="text-gray-500 hover:text-sky-500 transition">My Orders</a>
          </li>
          <li>
            <a href="/user/wishlist" class="text-gray-500 hover:text-sky-500 transition">Wishlist</a>
          </li>
          <li>
            <a href="/user/cart" class="text-gray-500 hover:text-sky-500 transition">Cart</a>
          </li>
          <li>
            <a href="/user/profile" class="text-gray-500 hover:text-sky-500 transition">Profile</a>
          </li>
        </ul>
      </div>

      <!-- COLUMN 4: NEWSLETTER -->
      <div class="space-y-4">
        <h4 class="text-xs font-black uppercase tracking-widest text-zinc-900 dark:text-white">
          Get Deals
        </h4>

        <p class="text-xs text-gray-500 dark:text-gray-400">
          Subscribe and get exclusive discounts & flash sale alerts.
        </p>

        <form action="/newsletter-signup" method="POST" class="flex gap-2">
          <input type="email" placeholder="Email address" required
            class="w-full text-xs px-3.5 py-2.5 rounded-xl bg-white dark:bg-zinc-800 border border-gray-200 dark:border-zinc-700 focus:border-sky-500 outline-none" />

          <button type="submit" class="bg-sky-500 hover:bg-sky-600 text-white p-2.5 rounded-xl transition">
            <svg class="h-4 w-4 rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
          </button>
        </form>
      </div>
    </div>

    <!-- DIVIDER -->
    <hr class="border-gray-200 dark:border-zinc-800 my-8" />

    <!-- BOTTOM BAR -->
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-gray-500 dark:text-gray-400">
      <p>
        © <span id="current-year">2026</span> Swift Basket. All rights
        reserved.
      </p>

      <div class="flex gap-4">
        <a href="/store/privacy-policy" class="hover:text-sky-500 transition">Privacy</a>
        <span>•</span>
        <a href="/store/terms" class="hover:text-sky-500 transition">Terms</a>
        <span>•</span>
        <a href="/store/support" class="hover:text-sky-500 transition">Support</a>
      </div>
    </div>
  </div>
</footer>
<script src="/js/ui/navbar.js"></script>
<script src="https://unpkg.com/lucide@latest"></script>
<script>document.addEventListener("DOMContentLoaded", () => lucide.createIcons())</script>
</body>
</html>