<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | SwiftBasket</title>
    <link
      rel="icon"
      href="https://images.unsplash.com/vector-1780599883133-df4851a972f2?q=80&w=880&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      type="image/svg+xml"
    />
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,0,0"
    />
    <script>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            fontFamily: { sans: ['"Nunito Sans"', "sans-serif"] },
            colors: {
              brand: {
                DEFAULT: "#FF385C",
                hover: "#E31C5F",
                light: "#FFF0F2",
                dark: "#2D1217",
              },
              dark: "#121212",
            },
            screens: {
              xs: "375px",
            },
          },
        },
      };
    </script>
    <script>
      if (
        localStorage.getItem("color-theme") === "dark" ||
        (!("color-theme" in localStorage) &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
    <style>
      /* Smooth custom scrollbars */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }

      ::-webkit-scrollbar-track {
        background: transparent;
      }

      .dark ::-webkit-scrollbar-thumb {
        background: #2d2d30;
        border-radius: 9999px;
      }

      ::-webkit-scrollbar-thumb {
        background: #e4e4e7;
        border-radius: 9999px;
      }

      /* Hide default scrollbars for smooth categories track */
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }

      .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </head>

  <body
    class="bg-gray-50 text-zinc-800 dark:bg-[#0C0C0E] dark:text-zinc-200 antialiased transition-colors duration-300 min-h-screen flex flex-col"
  >
    <header
      class="sticky top-0 z-50 bg-white/80 dark:bg-[#121214]/80 backdrop-blur-md border-b border-gray-200/60 dark:border-zinc-800/60 transition-colors duration-300"
    >
      <nav
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3.5 flex justify-between items-center gap-4"
      >
        <!-- Custom Brand Logo -->
        <a href="/" class="group flex items-center gap-2 select-none">
          <!-- SVG ICON -->
          <div class="relative">
            <svg
              class="h-7 w-7 text-sky-500 group-hover:text-sky-400 transition"
              viewBox="0 0 100 100"
              fill="none"
            >
              <!-- Cart -->
              <path
                d="M20 25 H30 L38 65 H75"
                stroke="currentColor"
                stroke-width="10"
                stroke-linecap="round"
                stroke-linejoin="round"
              />

              <!-- Wheels -->
              <circle cx="45" cy="75" r="6" fill="currentColor" />
              <circle cx="68" cy="75" r="6" fill="currentColor" />

              <!-- Growth Arrow -->
              <path
                d="M55 15 L55 45 M45 25 L55 15 L65 25"
                stroke="currentColor"
                stroke-width="8"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </div>

          <!-- BRAND TEXT -->
          <span
            class="font-black text-xl tracking-tight text-slate-900 dark:text-white"
          >
            SwiftBasket
          </span>
        </a>
        <!-- Header End Controls -->
        <div class="flex items-center gap-2 sm:gap-4 shrink-0">
          <!-- Modern Theme Toggle Button -->
          <button
            id="theme-toggle"
            class="p-2.5 rounded-full border border-gray-200 dark:border-zinc-800 hover:bg-gray-100 dark:hover:bg-zinc-800/80 text-zinc-500 dark:text-zinc-400 transition-all active:scale-95"
            aria-label="Toggle Theme"
          >
            <svg
              id="theme-toggle-sun"
              class="hidden h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M15 12a3 3 0 11-6 0 3 3 0 016 0z"
              />
            </svg>
            <svg
              id="theme-toggle-moon"
              class="hidden h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
              />
            </svg>
          </button>

          <!-- Dropdown Menu Switcher -->
          <div class="relative">
            <button
              id="menu-button"
              class="border border-gray-200 dark:border-zinc-800 bg-white dark:bg-[#161619] rounded-full py-1.5 px-2 sm:py-2 sm:px-3 hover:shadow-md transition-all flex items-center gap-2.5 sm:gap-3 focus:outline-none focus:ring-2 focus:ring-brand/40"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 text-zinc-500 dark:text-zinc-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"
                />
              </svg>
              <!-- Small avatar in header -->
              <div
                class="w-6 h-6 rounded-full bg-gradient-to-br from-sky-500 to-cyan-400 flex items-center justify-center text-white text-[10px] sm:text-xs font-bold ring-2 ring-white dark:ring-zinc-900"
              >
                <%= isLoggedIn ? user.firstName[0] : "U"%>
              </div>
              <!-- <img
                class="bg-zinc-800 dark:bg-zinc-700 rounded-full w-6 h-6 flex items-center justify-center text-white text-[10px] sm:text-xs font-bold ring-2 ring-gray-100 dark:ring-zinc-800"
                src="https://www.dropbox.com/scl/fi/8494k9sb99x5tyr4gxbqe/IMG_202605261733.JPG?rlkey=s973u0cenuvu4q697f9pe6v38&st=fnt6kq7b&raw=1"
              /> -->

            </button>

            <!-- Dropdown Menu Options -->
            <!-- COMPACT PREMIUM DROPDOWN -->
            <div
              id="menu-dropdown"
              class="hidden absolute right-0 top-full mt-2 w-72 max-h-[75vh] overflow-y-auto rounded-2xl border border-zinc-200/70 dark:border-zinc-800 bg-white/95 dark:bg-zinc-900/95 backdrop-blur-xl shadow-[0_20px_50px_rgba(0,0,0,0.15)] dark:shadow-[0_20px_50px_rgba(0,0,0,0.45)] z-50 scrollbar-thin scrollbar-thumb-zinc-300 dark:scrollbar-thumb-zinc-700"
            >
            <% if(isLoggedIn) {%>
              <!-- USER -->
              <div
                class="flex items-center gap-3 p-4 border-b border-zinc-100 dark:border-zinc-800"
              >
                <!-- Large avatar in dropdown -->
                <div
                  class="w-10 h-10 rounded-full bg-gradient-to-br from-sky-500 to-cyan-400 flex items-center justify-center text-white font-bold text-sm shadow-md"
                >
                  <%= user.firstName[0] %>
                </div>

                <div>
                  <h3 class="text-sm font-bold text-zinc-900 dark:text-white">
                    Welcome <%= user.firstName %>
                  </h3>
                  <p class="text-[11px] text-zinc-500 dark:text-zinc-400">
                    Manage your account
                  </p>
                </div>
              </div>
              <% if(user.accountType === "Admin") {%>
              <!-- ADMIN -->
              <div class="p-2">
                <p
                  class="px-3 pb-1 text-[10px] font-black uppercase tracking-[0.2em] text-zinc-400"
                >
                  Admin
                </p>

                <a
                  href="/admin/add-products"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm text-zinc-700 dark:text-zinc-300 hover:bg-sky-50 dark:hover:bg-sky-500/10 transition"
                >
                  <span class="material-symbols-rounded text-lg text-sky-500">
                    shield_person
                  </span>
                  Become Admin
                </a>

                <a
                  href="/admin/products"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm text-zinc-700 dark:text-zinc-300 hover:bg-sky-50 dark:hover:bg-sky-500/10 transition"
                >
                  <span class="material-symbols-rounded text-lg text-sky-500">
                    inventory_2
                  </span>
                  Admin Products
                </a>
              </div>
              <% } else {%>
              <div
                class="mx-3 border-t border-zinc-100 dark:border-zinc-800"
              ></div>

              <!-- SHOP -->
              <div class="p-2">
                <p
                  class="px-3 pb-1 text-[10px] font-black uppercase tracking-[0.2em] text-zinc-400"
                >
                  Shop
                </p>

                <a
                  href="/store/products"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm hover:bg-sky-50 dark:hover:bg-sky-500/10 transition"
                >
                  <span class="material-symbols-rounded text-lg text-sky-500">
                    shopping_bag
                  </span>
                  All Products
                </a>

                <a
                  href="/store/deals"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm hover:bg-orange-50 dark:hover:bg-orange-500/10 transition"
                >
                  <span
                    class="material-symbols-rounded text-lg text-orange-500"
                  >
                    local_fire_department
                  </span>
                  Hot Deals
                </a>

                <a
                  href="/store/categories"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm hover:bg-purple-50 dark:hover:bg-purple-500/10 transition"
                >
                  <span
                    class="material-symbols-rounded text-lg text-purple-500"
                  >
                    category
                  </span>
                  Categories
                </a>

                <a
                  href="/store/new-arrival"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition"
                >
                  <span
                    class="material-symbols-rounded text-lg text-emerald-500"
                  >
                    auto_awesome
                  </span>
                  New Arrivals
                </a>
              </div>

              <div
                class="mx-3 border-t border-zinc-100 dark:border-zinc-800"
              ></div>
              <%}%>
              <!-- ACCOUNT -->
              <div class="p-2">
                <p
                  class="px-3 pb-1 text-[10px] font-black uppercase tracking-[0.2em] text-zinc-400"
                >
                  Account
                </p>

                <a
                  href="/user/profile"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm hover:bg-sky-50 dark:hover:bg-sky-500/10 transition"
                >
                  <span class="material-symbols-rounded text-lg text-sky-500">
                    person
                  </span>
                  Profile
                </a>

                <a
                  href="/user/wishlist"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm hover:bg-pink-50 dark:hover:bg-pink-500/10 transition"
                >
                  <span class="material-symbols-rounded text-lg text-pink-500">
                    favorite
                  </span>
                  Wishlist
                </a>

                <a
                  href="/user/cart"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm hover:bg-cyan-50 dark:hover:bg-cyan-500/10 transition"
                >
                  <span class="material-symbols-rounded text-lg text-cyan-500">
                    shopping_cart
                  </span>
                  Cart
                </a>

                <a
                  href="/user/orders"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm hover:bg-amber-50 dark:hover:bg-amber-500/10 transition"
                >
                  <span class="material-symbols-rounded text-lg text-amber-500">
                    package_2
                  </span>
                  My Orders
                </a>
              </div>

              <div
                class="mx-3 border-t border-zinc-100 dark:border-zinc-800"
              ></div>
              <!-- AUTH -->
              <div class="p-2">
                <form action="/auth/logout" method="POST"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm hover:bg-green-50 dark:hover:bg-green-500/10 transition"
                >
                  <span class="material-symbols-rounded text-lg text-green-500">
                    logout
                  </span>
                  <button>
                    Logout
                  </button>
                </form>
                </div>
              <% } %>
              <% if(!isLoggedIn) {%>
              <!-- AUTH -->
              <div class="p-2">
                <a
                  href="/auth/signup"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm hover:bg-green-50 dark:hover:bg-green-500/10 transition"
                >
                  <span class="material-symbols-rounded text-lg text-green-500">
                    person_add
                  </span>
                  Sign Up
                </a>

                <a
                  href="/auth/login"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm hover:bg-green-50 dark:hover:bg-green-500/10 transition"
                >
                  <span class="material-symbols-rounded text-lg text-green-500">
                    login
                  </span>
                  Log In
                </a>
              </div>

              <% } %>
              <% if(isLoggedIn) {%>
                <div
                  class="mx-3 border-t border-zinc-100 dark:border-zinc-800"
                ></div>
              <!-- FOOTER -->
              <div class="p-2">
                <a
                  href="/"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm hover:bg-zinc-100 dark:hover:bg-zinc-800 transition"
                >
                  <span class="material-symbols-rounded text-lg text-zinc-500">
                    home
                  </span>
                  Return Home
                </a>

                <a
                  href="/store/help-center"
                  class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm hover:bg-zinc-100 dark:hover:bg-zinc-800 transition"
                >
                  <span class="material-symbols-rounded text-lg text-zinc-500">
                    help
                  </span>
                  Help Center
                </a>
              </div>
              <%}%>
            </div>
          </div>
        </div>
      </nav>
    </header>
  </body>
</html>
