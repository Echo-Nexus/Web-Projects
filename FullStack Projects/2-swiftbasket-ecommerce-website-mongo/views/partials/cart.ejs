
<main class="w-full min-h-screen py-12 px-4 sm:px-6 lg:px-8 bg-gray-50 dark:bg-gray-950 transition-colors duration-500 font-['Nunito_Sans',_sans-serif]">

  <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest"></script>

  <div class="max-w-6xl mx-auto space-y-8">
    <div class="flex items-center justify-between pb-8 border-b border-gray-200 dark:border-zinc-800">
      <div>
        <h1 class="text-4xl font-black text-gray-900 dark:text-white tracking-tight">Your Shopping Cart</h1>
        <p class="text-gray-500 dark:text-zinc-400 mt-2">Manage your selected items and proceed to checkout.</p>
      </div>
      <div class="hidden md:block text-right">
        <p class="text-sm font-bold text-gray-400 uppercase tracking-widest">Total Items</p>
        <p class="text-2xl font-black text-gray-900 dark:text-white" id="itemCountDisplay">0</p>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Cart Items Section -->
      <div class="lg:col-span-2 space-y-4" id="cartContainer">
        <!-- Dynamic content -->
      </div>

      <!-- Summary Panel -->
      <div class="bg-white dark:bg-gray-900 rounded-3xl p-8 border border-gray-100 dark:border-zinc-800 shadow-sm h-fit space-y-6">
        <h2 class="text-xl font-black text-gray-900 dark:text-white">Order Summary</h2>
        <div class="space-y-4">
          <div class="flex justify-between text-gray-500 dark:text-zinc-400">
            <span>Subtotal</span>
            <span class="font-bold text-gray-900 dark:text-white">$999.00</span>
          </div>
          <div class="flex justify-between text-gray-500 dark:text-zinc-400">
            <span>Shipping</span>
            <span class="font-bold text-emerald-500">Free</span>
          </div>
          <div class="pt-4 border-t border-gray-100 dark:border-zinc-800 flex justify-between items-center">
            <span class="text-lg font-bold">Total</span>
            <span class="text-3xl font-black text-gray-900 dark:text-white">$999.00</span>
          </div>
        </div>
        <button onclick="checkout()" class="w-full py-4 rounded-xl bg-rose-500 hover:bg-rose-600 text-white font-black transition-all active:scale-95 shadow-lg shadow-rose-500/20">
          Proceed to Checkout
        </button>
      </div>
    </div>
  </div>

  <script>
    (function() {
      const cartItems = [
        { 
          id: "77c1a060-8941-4354-96bb-74251ab419b7",
          title: "Iphone 7 Plus",
          price: "999",
          image: "https://images.unsplash.com/photo-1589492477829-5e65395b66cc?q=80&w=687&auto=format&fit=crop"
        }
      ];

      function renderCart() {
        const container = document.getElementById('cartContainer');
        const countDisplay = document.getElementById('itemCountDisplay');
        
        countDisplay.textContent = cartItems.length;
        container.innerHTML = cartItems.map(item => `
          <div class="bg-white dark:bg-gray-900 border border-gray-100 dark:border-zinc-800 p-4 rounded-2xl flex items-center gap-4 group">
            <img src="${item.image}" class="w-20 h-20 rounded-xl object-cover" />
            <div class="flex-grow">
              <h3 class="font-black text-lg text-gray-900 dark:text-white">${item.title}</h3>
              <p class="text-rose-500 font-bold">$${item.price}</p>
            </div>
            <button class="p-3 bg-gray-50 dark:bg-zinc-800 rounded-xl text-gray-400 hover:text-rose-500 transition-colors">
              <i data-lucide="trash-2" class="w-5 h-5"></i>
            </button>
          </div>
        `).join('');
        lucide.createIcons();
      }

      window.checkout = () => console.log("Checkout triggered");
      window.addEventListener('DOMContentLoaded', renderCart);
    })();
  </script>
</main>