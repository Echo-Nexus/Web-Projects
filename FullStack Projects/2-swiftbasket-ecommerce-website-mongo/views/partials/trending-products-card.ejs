<!-- ================= TRENDING PRODUCTS ================= -->
<section class="max-w-7xl mx-auto py-16 px-4 sm:px-6 lg:px-8 text-slate-900 dark:text-white">
  <div class="flex items-end justify-between mb-10 border-b border-gray-100 dark:border-zinc-900 pb-6">
    <div>
      <h2 class="text-3xl font-black tracking-tight">Trending Products</h2>
      <p class="text-sm text-gray-500 dark:text-zinc-400 mt-1">Discover the most sought-after listings this week</p>
    </div>

    <a href="/store/products"
      class="inline-flex items-center gap-1 text-sm font-bold text-sky-500 hover:text-sky-600 hover:underline transition">
      View All
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>

  <!-- Responsive Product Grid Block -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
    <% products.slice(0,8).forEach(product=> { %>
      <%- include("../partials/product-card", { product }) %>
        <% }) %>
  </div>
</section>