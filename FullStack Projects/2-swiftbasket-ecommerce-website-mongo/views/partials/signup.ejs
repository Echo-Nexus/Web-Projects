<%- include("../partials/header") %>
  <main
    class="w-full min-h-screen py-12 px-4 sm:px-6 lg:px-8 flex items-center justify-center relative overflow-hidden bg-gray-50 text-[#222222] dark:bg-gray-950 dark:text-white transition-colors duration-500 font-['Nunito_Sans',_sans-serif]">
    <!-- Embedding Google Font Link dynamically inside the module to preserve self-containment -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700;800;900&display=swap"
      rel="stylesheet" />

    <style>
      @keyframes float-slow {

        0%,
        100% {
          transform: translateY(0px) rotate(0deg);
        }

        50% {
          transform: translateY(-15px) rotate(3deg);
        }
      }

      @keyframes float-medium {

        0%,
        100% {
          transform: translateY(0px) rotate(0deg);
        }

        50% {
          transform: translateY(-10px) rotate(-3deg);
        }
      }

      @keyframes float-fast {

        0%,
        100% {
          transform: translateY(0px);
        }

        50% {
          transform: translateY(-6px);
        }
      }

      @keyframes pulse-ring {
        0% {
          transform: scale(0.95);
          opacity: 0.5;
        }

        50% {
          transform: scale(1.05);
          opacity: 0.8;
        }

        100% {
          transform: scale(0.95);
          opacity: 0.5;
        }
      }

      @keyframes draw-path {
        to {
          stroke-dashoffset: 0;
        }
      }

      .animate-float-slow {
        animation: float-slow 6.5s ease-in-out infinite;
      }

      .animate-float-medium {
        animation: float-medium 5s ease-in-out infinite;
      }

      .animate-float-fast {
        animation: float-fast 3.5s ease-in-out infinite;
      }

      .animate-pulse-ring {
        animation: pulse-ring 4.5s ease-in-out infinite;
      }

      .svg-line-draw {
        stroke-dasharray: 100;
        stroke-dashoffset: 100;
        animation: draw-path 2.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
      }
    </style>

    <!-- Ambient Glow Background Orbs positioned absolutely inside parent container -->
    <div
      class="absolute top-0 left-0 w-72 h-72 sm:w-96 sm:h-96 rounded-full bg-rose-400/10 dark:bg-brand-500/5 blur-[120px] pointer-events-none select-none transition-all duration-500">
    </div>
    <div
      class="absolute bottom-0 right-0 w-72 h-72 sm:w-96 sm:h-96 rounded-full bg-sky-400/10 dark:bg-sky-500/5 blur-[120px] pointer-events-none select-none transition-all duration-500">
    </div>

    <!-- Main Card Grid Structure -->
    <div
      class="w-full max-w-6xl bg-white/75 dark:bg-gray-900/40 border border-gray-200/60 dark:border-gray-800/60 backdrop-blur-2xl rounded-[32px] overflow-hidden shadow-2xl dark:shadow-black/40 p-6 sm:p-10 lg:p-14 transition-all duration-500 relative z-10">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <!-- Left Side Column: Premium Animated Vector Graphic -->
        <div
          class="lg:col-span-5 hidden lg:flex flex-col items-center justify-center text-center space-y-8 select-none">
          <div class="relative w-full max-w-sm aspect-square flex items-center justify-center">
            <!-- Pulsing Ambient Radial Shadow Ring -->
            <div
              class="absolute inset-4 bg-gradient-to-tr from-[#FF385C]/10 to-indigo-500/10 rounded-full animate-pulse-ring blur-xl">
            </div>

            <!-- Custom Curated Vector SVG representing Delivery, Commerce, and security checkout -->
            <svg class="w-full h-full relative z-10" viewBox="0 0 400 400" fill="none"
              xmlns="http://www.w3.org/2000/svg">
              <g class="animate-float-slow">
                <circle cx="200" cy="200" r="100" fill="url(#grad1)" opacity="0.15" />
                <path class="svg-line-draw" d="M110 140 H140 L165 240 H250 L275 140 H145" stroke="#FF385C"
                  stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="180" cy="270" r="15" fill="#FF385C" />
                <circle cx="235" cy="270" r="15" fill="#FF385C" />
              </g>

              <g class="animate-float-medium">
                <rect x="175" y="110" width="60" height="50" rx="8" fill="url(#grad2)" stroke="#818CF8"
                  stroke-width="4" />
                <line x1="175" y1="135" x2="235" y2="135" stroke="#818CF8" stroke-width="3" />
                <line x1="205" y1="110" x2="205" y2="160" stroke="#818CF8" stroke-width="3" />
              </g>

              <g class="animate-float-fast">
                <path d="M90 100 L95 110 L105 112 L97 120 L100 130 L90 124 L80 130 L83 120 L75 112 L85 110 Z"
                  fill="#FBBF24" />
                <circle cx="310" cy="120" r="16" fill="#FBBF24" stroke="#D97706" stroke-width="3" />
                <text x="306" y="125" fill="#D97706" font-family="Nunito Sans" font-weight="900" font-size="16">
                  $
                </text>
                <circle cx="300" cy="240" r="6" fill="#60A5FA" class="animate-ping" />
                <circle cx="100" cy="230" r="4" fill="#34D399" />
              </g>

              <defs>
                <linearGradient id="grad1" x1="100" y1="100" x2="300" y2="300" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#FF385C" />
                  <stop offset="100%" stop-color="#818CF8" />
                </linearGradient>
                <linearGradient id="grad2" x1="175" y1="110" x2="235" y2="160" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#818CF8" />
                  <stop offset="100%" stop-color="#4F46E5" />
                </linearGradient>
              </defs>
            </svg>
          </div>

          <div class="space-y-3 max-w-xs">
            <h2 class="text-2xl font-black tracking-tight text-gray-900 dark:text-white">
              Unlock Exclusive Perks
            </h2>
            <p class="text-sm text-gray-500 dark:text-zinc-400 leading-relaxed">
              Create an account to gain early access to flash sales, customized
              reward portals, and instant lightning checkouts.
            </p>
          </div>
        </div>

        <!-- Right Side Column: Modern Form Interface -->
        <div class="lg:col-span-7 w-full flex flex-col justify-center">
          <div class="max-w-md w-full mx-auto space-y-8">
            <div class="text-left">
              <h1 class="text-3xl sm:text-4xl font-black text-gray-900 dark:text-white tracking-tight">
                Create Account
              </h1>
              <p class="text-sm text-gray-500 dark:text-zinc-400 mt-2">
                Join SwiftBasket today. Already have an account?
                <a href="/login" class="text-[#FF385C] hover:underline font-bold transition">Sign In</a>
              </p>
            </div>

            <!-- Main Input Stream Form -->
            <form id="signupForm" method="post" action="/auth/signup" class="space-y-5">
              <!-- Input: Full Name -->
              <div class="group">
                <label
                  class="block text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-zinc-400 mb-2 group-focus-within:text-[#FF385C] transition-colors">
                  Full Name
                </label>
                <div class="relative">
                  <span
                    class="absolute left-4 top-3.5 text-gray-400 group-focus-within:text-[#FF385C] transition-colors">
                    <i data-lucide="user" class="w-5 h-5"></i>
                  </span>
                  <input type="text" required id="fullName" placeholder="e.g. Alexander Pierce" name="fullname"
                    class="w-full pl-12 pr-4 py-3.5 rounded-2xl border bg-gray-50/50 text-gray-900 border-gray-200/80 dark:bg-gray-800/40 dark:text-white dark:border-zinc-800/80 focus:ring-2 focus:ring-[#FF385C] focus:bg-white dark:focus:bg-gray-900 focus:outline-none transition-all duration-300" />
                </div>
              </div>

              <!-- Input: Email -->
              <div class="group">
                <label
                  class="block text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-zinc-400 mb-2 group-focus-within:text-[#FF385C] transition-colors">
                  Email Address
                </label>
                <div class="relative">
                  <span
                    class="absolute left-4 top-3.5 text-gray-400 group-focus-within:text-[#FF385C] transition-colors">
                    <i data-lucide="mail" class="w-5 h-5"></i>
                  </span>
                  <input type="email" required id="emailAddr" placeholder="you@example.com" name="email"
                    class="w-full pl-12 pr-4 py-3.5 rounded-2xl border bg-gray-50/50 text-gray-900 border-gray-200/80 dark:bg-gray-800/40 dark:text-white dark:border-zinc-800/80 focus:ring-2 focus:ring-[#FF385C] focus:bg-white dark:focus:bg-gray-900 focus:outline-none transition-all duration-300" />
                </div>
              </div>

              <!-- Input: Password with live, integrated strength detector -->
              <div class="group">
                <label
                  class="block text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-zinc-400 mb-2 group-focus-within:text-[#FF385C] transition-colors">
                  Password
                </label>
                <div class="relative">
                  <span
                    class="absolute left-4 top-3.5 text-gray-400 group-focus-within:text-[#FF385C] transition-colors">
                    <i data-lucide="lock" class="w-5 h-5"></i>
                  </span>
                  <input type="password" required id="pwd" placeholder="••••••••••••" name="password"
                    class="w-full pl-12 pr-12 py-3.5 rounded-2xl border bg-gray-50/50 text-gray-900 border-gray-200/80 dark:bg-gray-800/40 dark:text-white dark:border-zinc-800/80 focus:ring-2 focus:ring-[#FF385C] focus:bg-white dark:focus:bg-gray-900 focus:outline-none transition-all duration-300" />
                  <!-- Visibility toggling toggle button -->
                  <button type="button" id="pwdToggle"
                    class="absolute right-4 top-3.5 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition">
                    <i data-lucide="eye" class="w-5 h-5"></i>
                  </button>
                </div>

                <!-- Password Strength visual output tracker -->
                <div id="strengthContainer" class="mt-3 hidden transition-all duration-300">
                  <div class="flex items-center justify-between text-xs mb-1.5">
                    <span class="text-gray-400 dark:text-zinc-500 font-semibold">Security Assessment:</span>
                    <span id="strengthLabel"
                      class="font-bold uppercase tracking-wider text-gray-400 dark:text-zinc-500">Not assessed</span>
                  </div>
                  <!-- Interactive split progress level bars -->
                  <div
                    class="grid grid-cols-3 gap-1.5 h-1.5 rounded-full bg-gray-100 dark:bg-zinc-800/60 overflow-hidden">
                    <div id="strengthBar1"
                      class="h-full rounded-full bg-gray-200 dark:bg-zinc-800 transition-all duration-300"></div>
                    <div id="strengthBar2"
                      class="h-full rounded-full bg-gray-200 dark:bg-zinc-800 transition-all duration-300"></div>
                    <div id="strengthBar3"
                      class="h-full rounded-full bg-gray-200 dark:bg-zinc-800 transition-all duration-300"></div>
                  </div>
                  <p id="strengthFeedback"
                    class="text-[10px] text-gray-400 dark:text-zinc-500 mt-1.5 font-medium leading-normal">
                    Enter characters to evaluate strength profile.
                  </p>
                </div>
              </div>

              <!-- Checkbox Option: Accept Terms and Service Policies -->
              <div class="flex items-start gap-3 pt-1">
                <div class="relative flex items-center h-5">
                  <input type="checkbox" required id="terms" name="terms" value="accepted"
                    class="w-5 h-5 rounded-lg border-gray-300 text-[#FF385C] focus:ring-[#FF385C] dark:bg-gray-800/50 dark:border-zinc-800 cursor-pointer transition" />
                </div>
                <label for="terms"
                  class="text-xs sm:text-sm text-gray-500 dark:text-zinc-400 select-none cursor-pointer">
                  I agree to the
                  <a href="/terms" class="text-[#FF385C] font-semibold hover:underline">Terms of Service</a>
                  and
                  <a href="/privacy" class="text-[#FF385C] font-semibold hover:underline">Privacy Policy</a>.
                </label>
              </div>

              <!-- Dynamic absolute color CTA checkout submit button -->
              <div class="pt-2">
                <button type="submit" id="submitBtn"
                  class="w-full bg-[#FF385C] hover:bg-[#e01e43] text-white font-bold py-4 px-6 rounded-2xl transition-all duration-200 active:scale-[0.98] shadow-lg shadow-rose-500/20 hover:shadow-rose-500/35 flex items-center justify-center gap-2">
                  <i data-lucide="user-plus" class="w-5 h-5"></i>
                  <span>Register Account</span>
                </button>
              </div>
            </form>

            <!-- Success Confirmation Pop-Up (integrated directly within the form card block) -->
            <div id="successPanel"
              class="hidden p-4 rounded-2xl bg-emerald-50 border border-emerald-200 dark:bg-emerald-500/10 dark:border-emerald-500/20 flex gap-3.5 items-center transition-all duration-300">
              <span
                class="w-10 h-10 rounded-full bg-emerald-100 dark:bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 flex items-center justify-center flex-shrink-0 animate-bounce">
                <i data-lucide="check" class="w-6 h-6"></i>
              </span>
              <div>
                <h4 class="font-bold text-emerald-800 dark:text-emerald-400 text-sm">
                  Welcome aboard, <span id="regUser">Merchant</span>!
                </h4>
                <p class="text-xs text-emerald-600/80 dark:text-emerald-400/80">
                  Your SwiftBasket account has been created. Redirecting to store
                  setup...
                </p>
              </div>
            </div>

            <!-- Third Party Platforms (Social authentication pathways) -->
            <div class="space-y-4 pt-4 border-t border-gray-100 dark:border-zinc-800/80">
              <p class="text-center text-xs font-bold uppercase tracking-wider text-gray-400 dark:text-zinc-500">
                Or continue with
              </p>

              <div class="grid grid-cols-2 gap-4">
                <button type="button"
                  class="flex items-center justify-center gap-2 py-3 px-4 rounded-xl border border-gray-200 dark:border-zinc-800 bg-white/50 dark:bg-zinc-900/40 hover:bg-gray-50 dark:hover:bg-zinc-800/60 transition active:scale-95 text-xs sm:text-sm font-bold">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                    <path
                      d="M12.24 10.285V13.4h6.887c-.275 1.565-1.88 4.604-6.887 4.604-4.33 0-7.866-3.577-7.866-8s3.536-8 7.866-8c2.46 0 4.105 1.025 5.047 1.926l2.427-2.334C17.955 2.192 15.34 1 12.24 1 6.033 1 12.24s5.033 11.24 11.24 11.24c6.478 0 10.793-4.537 10.793-10.986 0-.743-.08-1.3-.176-1.859H12.24z" />
                  </svg>
                  Google
                </button>
                <button type="button"
                  class="flex items-center justify-center gap-2 py-3 px-4 rounded-xl border border-gray-200 dark:border-zinc-800 bg-white/50 dark:bg-zinc-900/40 hover:bg-gray-50 dark:hover:bg-zinc-800/60 transition active:scale-95 text-xs sm:text-sm font-bold">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                    <path
                      d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" />
                  </svg>
                  Facebook
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Dynamic Javascript Block nested safely inside <main> to execute upon loading inside your EJS template -->
<script>
(function () {
  // Lucide Icons
  if (typeof lucide !== "undefined") {
    lucide.createIcons();
  }

  // Password Toggle
  const passwordInput = document.getElementById("pwd");
  const pwdToggle = document.getElementById("pwdToggle");
  let isPwdVisible = false;

  if (pwdToggle && passwordInput) {
    pwdToggle.addEventListener("click", () => {
      isPwdVisible = !isPwdVisible;
      passwordInput.type = isPwdVisible ? "text" : "password";

      pwdToggle.innerHTML = isPwdVisible
        ? `<i data-lucide="eye-off" class="w-5 h-5"></i>`
        : `<i data-lucide="eye" class="w-5 h-5"></i>`;

      if (typeof lucide !== "undefined") {
        lucide.createIcons();
      }
    });
  }

  // Password Strength
  const strengthContainer = document.getElementById("strengthContainer");
  const strengthLabel = document.getElementById("strengthLabel");
  const strengthFeedback = document.getElementById("strengthFeedback");
  const bar1 = document.getElementById("strengthBar1");
  const bar2 = document.getElementById("strengthBar2");
  const bar3 = document.getElementById("strengthBar3");

  if (passwordInput) {
    passwordInput.addEventListener("input", () => {
      const password = passwordInput.value;

      if (!password) {
        strengthContainer.classList.add("hidden");
        return;
      }

      strengthContainer.classList.remove("hidden");

      let score = 0;

      const lengthScore = password.length >= 8;
      const caseScore =
        /[A-Z]/.test(password) && /[a-z]/.test(password);
      const numberScore = /[0-9]/.test(password);
      const specialScore = /[^A-Za-z0-9]/.test(password);

      if (password.length >= 6) score++;
      if (lengthScore) score++;
      if (caseScore) score++;
      if (numberScore) score++;
      if (specialScore) score++;

      const resetBars = () => {
        bar1.className =
          "h-full rounded-full transition-all duration-300 bg-gray-200 dark:bg-zinc-800";
        bar2.className =
          "h-full rounded-full transition-all duration-300 bg-gray-200 dark:bg-zinc-800";
        bar3.className =
          "h-full rounded-full transition-all duration-300 bg-gray-200 dark:bg-zinc-800";
      };

      resetBars();

      if (password.length < 6) {
        strengthLabel.textContent = "Too Short";
        bar1.classList.add("bg-rose-500");
        strengthFeedback.textContent =
          "Password must be at least 6 characters.";
      } else if (score <= 2) {
        strengthLabel.textContent = "Weak";
        bar1.classList.add("bg-orange-500");
        strengthFeedback.textContent =
          "Add uppercase letters, numbers, and symbols.";
      } else if (score <= 4) {
        strengthLabel.textContent = "Medium";
        bar1.classList.add("bg-amber-500");
        bar2.classList.add("bg-amber-500");
        strengthFeedback.textContent =
          "Add more complexity for better security.";
      } else {
        strengthLabel.textContent = "Strong";
        bar1.classList.add("bg-emerald-500");
        bar2.classList.add("bg-emerald-500");
        bar3.classList.add("bg-emerald-500");
        strengthFeedback.textContent =
          "Excellent password strength.";
      }
    });
  }

  // Normal Form Submission
  const signupForm = document.getElementById("signupForm");

  if (signupForm) {
    signupForm.addEventListener("submit", () => {
      console.log("Submitting form...");
      // NO e.preventDefault()
    });
  }
})();
</script>
  </main>
  <%- include("../partials/footer") %>