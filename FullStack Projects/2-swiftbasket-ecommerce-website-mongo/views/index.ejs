          <!-- Modern Dynamic Cart Icon Mockup -->
          <div
            class="relative z-10 w-44 h-44 rounded-2xl bg-white/10 dark:bg-black/20 border border-white/20 flex items-center justify-center shadow-lg transform group-hover:scale-105 group-hover:rotate-1 transition-all duration-500"
          >
