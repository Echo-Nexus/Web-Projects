          >
            <svg
              class="w-5 h-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"
              />
            </svg>
            Shop Now
          </a>

          <a
            href="/admin/add-products"
            class="px-8 py-4 bg-white/5 hover:bg-white/10 text-white border border-white/10 rounded-2xl font-bold transition-all duration-200 backdrop-blur-sm active:scale-[0.98] flex items-center gap-2"
          >
            <svg
              class="w-5 h-5 text-sky-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            Sell Product
          </a>
        </div>
      </div>

      <!-- Hero Illustration (Visual Mock) -->
      <div class="lg:col-span-5 relative flex justify-center">
        <div
          class="relative w-full max-w-md aspect-square rounded-3xl bg-gradient-to-tr from-sky-500/20 to-purple-500/20 border border-white/10 p-8 flex items-center justify-center overflow-hidden group shadow-2xl shadow-indigo-950/50"
