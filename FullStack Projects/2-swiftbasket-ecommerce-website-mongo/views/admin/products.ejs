<%- include("../partials/header") %>
  <!-- Redesigned Main Content Area -->
  <main class="py-10 sm:py-16 px-4 sm:px-6 lg:px-8 flex-1 relative z-10">
    <div class="max-w-7xl mx-auto">
      <!-- Section Header -->
      <div
        class="mb-10 sm:mb-14 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 border-b border-gray-100 dark:border-gray-900 pb-6 animate-fadeInUp">
        <div class="text-left">
          <span
            class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-rose-50 text-[#FF385C] dark:bg-[#FF385C]/10 dark:text-[#FF385C] mb-3 uppercase tracking-wider">
            <i data-lucide="compass" class="w-3.5 h-3.5"></i> Curated Collection
          </span>
          <h1 class="text-3xl sm:text-4xl font-black text-gray-900 dark:text-white tracking-tight">
            Premium Picks for You
          </h1>
          <p class="text-gray-500 dark:text-gray-400 mt-1 text-sm sm:text-base">
            Explore premium acoustics, high-end electronics, and luxurious
            essentials.
          </p>
        </div>
        <div
          class="flex items-center gap-2 text-xs sm:text-sm font-bold text-gray-400 dark:text-gray-500 bg-white dark:bg-gray-900/60 border border-gray-100 dark:border-gray-850 px-4 py-2 rounded-xl self-start sm:self-auto">
          <span class="inline-block w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          Showing all premium results
        </div>
      </div>

      <!-- High-End Redesigned Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10" id="productGrid">

        <!-- Extra Mock Card 5 -->
        <% products.forEach(product=> { %>
          <div
            class="group flex flex-col justify-between h-full bg-white dark:bg-gray-900/40 rounded-[28px] overflow-hidden border border-gray-100 dark:border-gray-900 shadow-sm hover:shadow-xl dark:hover:shadow-black/20 hover:-translate-y-1 transition-all duration-300 relative animate-fadeInUp"
            style="animation-delay: 0.3s">
            <div class="relative w-full aspect-[4/3] overflow-hidden bg-gray-100 dark:bg-zinc-800">
              <button
                class="absolute top-4 right-4 z-20 w-9 h-9 rounded-full bg-white/90 dark:bg-gray-950/80 backdrop-blur-md flex items-center justify-center text-gray-400 hover:text-[#FF385C] dark:text-gray-300 transition duration-200 shadow-md">
                <i data-lucide="heart" class="w-4 h-4 fill-transparent"></i>
              </button>
              <div
                class="absolute top-4 left-4 z-10 bg-gradient-to-r from-purple-500 to-pink-500 text-white text-[10px] font-black uppercase tracking-wider px-3 py-1.5 rounded-xl shadow-md">
                <%= product.badge %>
              </div>

                <img src="<%= product.image %>" alt="Retro Eyewear" onclick="window.location.href='/store/products/details/<%= product.id %>'"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" />
                <div
                  class="absolute bottom-4 left-4 bg-black/60 dark:bg-black/40 backdrop-blur-md px-3 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-widest text-white border border-white/10">
                  <%= product.category %>
                </div>
            </div>
            <div class="p-6 flex-1 flex flex-col justify-between">
              <div>
                <div class="flex items-start justify-between gap-2 mb-2">
                  <h2
                    class="text-base sm:text-lg font-extrabold text-gray-900 dark:text-white hover:text-[#FF385C] transition-colors duration-200 line-clamp-1" onclick="window.location.href='/store/products/details/<%= product.id %>'">
                    <%= product.title %>
                  </h2>
                  <div
                    class="flex items-center gap-1 text-xs shrink-0 font-extrabold text-gray-800 dark:text-gray-200 bg-gray-50 dark:bg-gray-800 px-2.5 py-1 rounded-lg">
                    <i data-lucide="star" class="w-3.5 h-3.5 text-amber-500 fill-amber-500"></i>
                    <span>
                      <%= product.rating %>
                    </span>
                    <span class="text-gray-400 dark:text-gray-500 font-medium text-[10px]">
                      ( <%= product.reviews %>)
                    </span>
                  </div>
                </div>
                <p class="text-gray-500 dark:text-gray-400 text-xs font-semibold flex items-center gap-1.5 mb-3">
                  <i data-lucide="map-pin" class="w-3.5 h-3.5 text-gray-400 shrink-0"></i>
                  <%= product.location%>
                </p>
                <p class="text-gray-400 dark:text-gray-500 text-xs line-clamp-3 leading-relaxed min-h-[3.3rem]">
                  <%= product.description %>
                </p>
              </div>
              <div
                class="mt-6 pt-5 border-t border-gray-100 dark:border-gray-850/80 flex items-center justify-between gap-2">
                <div class="flex flex-col">
                  <span class="text-[9px] text-gray-400 dark:text-gray-500 font-bold tracking-wider uppercase">Premium
                    Price</span>
                  <span class="font-black text-xl sm:text-2xl text-gray-900 dark:text-white leading-none">$ <%=
                      product.price %></span>
                </div>
                <div class="flex items-center gap-2">
                  <!-- Actions (Edit + Delete) -->
                  <div class="flex items-center gap-2">

                    <!-- Delete -->
                    <form action="/admin/delete-product/<%= product.id %>" method="POST">
                      <button type="submit"
                        class="bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-3 rounded-lg flex items-center justify-center gap-1.5 transition-all duration-200 active:scale-[0.96] hover:shadow-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900 text-xs sm:text-sm">
                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                        <span>Delete</span>
                      </button>
                    </form>

                    <!-- Edit -->
                    <a href="/admin/edit-product/<%= product.id %>?editing=true"
                      class="bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 dark:hover:bg-gray-700 text-gray-900 dark:text-white font-bold py-2 px-3 rounded-lg flex items-center justify-center gap-1.5">

                      <i data-lucide="edit-3" class="w-4 h-4"></i>
                      <span>Edit</span>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <% }); %>
      </div>
    </div>
  </main>
  <%- include("../partials/footer") %>