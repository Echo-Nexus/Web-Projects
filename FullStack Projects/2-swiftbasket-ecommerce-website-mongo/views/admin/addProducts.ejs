<%- include("../partials/header") %>
  <main class="min-h-screen flex items-center justify-center p-4 sm:p-6 md:p-10 transition-colors duration-300">
    <div
      class="w-full max-w-2xl rounded-3xl shadow-2xl border bg-white border-gray-200 dark:bg-gray-900/60 dark:border-gray-800/80 backdrop-blur-xl p-6 sm:p-8 md:p-10 transition-colors duration-300">
      <!-- Header -->
      <div class="mb-8">
        <span
          class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-sky-50 text-sky-600 dark:bg-sky-500/10 dark:text-sky-400 mb-3">
          <i data-lucide="package-plus" class="w-3.5 h-3.5"></i> Merchant Portal
        </span>
        <h1
          class="text-3xl sm:text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-sky-600 to-indigo-600 dark:from-sky-400 dark:to-indigo-400">
          <%= editing ? "Edit " : "Add " %>Product
        </h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1.5">
          <%= editing
            ? "Refine and update your product details to keep your listing accurate, engaging, and professional."
            : "Create a stunning, optimized product listing with full professional details." %>
        </p>
      </div>
      <form action="<%= editing ? '/admin/success' : '/admin/product-added' %>"method="POST"id="productForm" class="space-y-5" method="POST">
        <% if (editing) { %>
          <input type="hidden" name="id" value="<%= product.id || '' %>">
          <%}%>

            <!-- Title -->
            <div class="group">
              <label
                class="block text-sm font-medium mb-1.5 text-gray-700 dark:text-gray-300 group-focus-within:text-sky-500 transition-colors">
                Product Title
              </label>
              <div class="relative">
                <span class="absolute left-4 top-3.5 text-gray-400 group-focus-within:text-sky-500 transition-colors">
                  <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                </span>
                <input type="text" id="prodTitle" name="title" value="<%= editing ? product.title : '' %>" required
                  placeholder="e.g: AeroSound ANC Headphones"
                  class="w-full pl-12 pr-4 py-3 rounded-xl border bg-gray-50/50 text-gray-900 border-gray-300/80 dark:bg-gray-800/50 dark:text-white dark:border-gray-700/80 focus:ring-2 focus:ring-sky-500 focus:bg-white dark:focus:bg-gray-800 focus:outline-none transition-all duration-200" />
              </div>
            </div>

            <!-- Category + Price -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="group">
                <label
                  class="block text-sm font-medium mb-1.5 text-gray-700 dark:text-gray-300 group-focus-within:text-sky-500 transition-colors">
                  Category
                </label>
                <div class="relative">
                  <span class="absolute left-4 top-3.5 text-gray-400 group-focus-within:text-sky-500 transition-colors">
                    <i data-lucide="tag" class="w-5 h-5"></i>
                  </span>
                  <input type="text" id="prodCategory" value="<%= editing ? product.category : ''%>" name="category"
                    required placeholder="e.g: Electronics"
                    class="w-full pl-12 pr-4 py-3 rounded-xl border bg-gray-50/50 text-gray-900 border-gray-300/80 dark:bg-gray-800/50 dark:text-white dark:border-gray-700/80 focus:ring-2 focus:ring-sky-500 focus:bg-white dark:focus:bg-gray-800 focus:outline-none transition-all duration-200" />
                </div>
              </div>

              <div class="group">
                <label
                  class="block text-sm font-medium mb-1.5 text-gray-700 dark:text-gray-300 group-focus-within:text-sky-500 transition-colors">
                  Price ($)
                </label>
                <div class="relative">
                  <span class="absolute left-4 top-3.5 text-gray-400 group-focus-within:text-sky-500 transition-colors">
                    <i data-lucide="dollar-sign" class="w-5 h-5"></i>
                  </span>
                  <input type="number" id="prodPrice" name="price" value="<%= editing ? product.price : ''%>" required
                    min="0" placeholder="e.g: 299"
                    class="w-full pl-12 pr-4 py-3 rounded-xl border bg-gray-50/50 text-gray-900 border-gray-300/80 dark:bg-gray-800/50 dark:text-white dark:border-gray-700/80 focus:ring-2 focus:ring-sky-500 focus:bg-white dark:focus:bg-gray-800 focus:outline-none transition-all duration-200" />
                </div>
              </div>
            </div>

            <!-- Rating + Reviews -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="group">
                <label
                  class="block text-sm font-medium mb-1.5 text-gray-700 dark:text-gray-300 group-focus-within:text-sky-500 transition-colors">
                  Rating (0.0 to 5.0)
                </label>
                <div class="relative">
                  <span class="absolute left-4 top-3.5 text-gray-400 group-focus-within:text-sky-500 transition-colors">
                    <i data-lucide="star" class="w-5 h-5"></i>
                  </span>
                  <input type="text" inputmode="decimal" pattern="^(5(\.0)?|[0-4](\.[0-9])?)$" id="prodRating"
                    name="rating" value="<%= editing ? product.rating : '' %>" required placeholder="e.g: 4.8"
                    class="w-full pl-12 pr-4 py-3 rounded-xl border bg-gray-50/50 text-gray-900 border-gray-300/80 dark:bg-gray-800/50 dark:text-white dark:border-gray-700/80 focus:ring-2 focus:ring-sky-500 focus:bg-white dark:focus:bg-gray-800 focus:outline-none transition-all duration-200" />
                </div>
              </div>

              <div class="group">
                <label
                  class="block text-sm font-medium mb-1.5 text-gray-700 dark:text-gray-300 group-focus-within:text-sky-500 transition-colors">
                  Total Reviews
                </label>
                <div class="relative">
                  <span class="absolute left-4 top-3.5 text-gray-400 group-focus-within:text-sky-500 transition-colors">
                    <i data-lucide="message-square" class="w-5 h-5"></i>
                  </span>
                  <input type="number" id="prodReviews" name="reviews" value="<%= editing ? product.reviews : ''%>"
                    required min="0" placeholder="e.g: 199"
                    class="w-full pl-12 pr-4 py-3 rounded-xl border bg-gray-50/50 text-gray-900 border-gray-300/80 dark:bg-gray-800/50 dark:text-white dark:border-gray-700/80 focus:ring-2 focus:ring-sky-500 focus:bg-white dark:focus:bg-gray-800 focus:outline-none transition-all duration-200" />
                </div>
              </div>
            </div>

            <!-- Badge + Location -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <!-- Badge -->
              <div class="group">
                <label
                  class="block text-sm font-medium mb-1.5 text-gray-700 dark:text-gray-300 group-focus-within:text-sky-500 transition-colors">
                  Promo Badge
                </label>
                <div class="relative">
                  <span class="absolute left-4 top-3.5 text-gray-400 group-focus-within:text-sky-500 transition-colors">
                    <i data-lucide="award" class="w-5 h-5"></i>
                  </span>
                  <input type="text" id="prodBadge" name="badge" value="<%= editing ? product.badge : ''%>" required
                    placeholder="e.g: Best Seller, New, Sale"
                    class="w-full pl-12 pr-4 py-3 rounded-xl border bg-gray-50/50 text-gray-900 border-gray-300/80 dark:bg-gray-800/50 dark:text-white dark:border-gray-700/80 focus:ring-2 focus:ring-sky-500 focus:bg-white dark:focus:bg-gray-800 focus:outline-none transition-all duration-200" />
                </div>
              </div>

              <!-- Location -->
              <div class="group">
                <label
                  class="block text-sm font-medium mb-1.5 text-gray-700 dark:text-gray-300 group-focus-within:text-sky-500 transition-colors">
                  Product Location
                </label>
                <div class="relative">
                  <span class="absolute left-4 top-3.5 text-gray-400 group-focus-within:text-sky-500 transition-colors">
                    <i data-lucide="map-pin" class="w-5 h-5"></i>
                  </span>
                  <input type="text" id="prodLocation" name="location" value="<%= editing ? product.location : ''%>"
                    required placeholder="e.g: New York, USA"
                    class="w-full pl-12 pr-4 py-3 rounded-xl border bg-gray-50/50 text-gray-900 border-gray-300/80 dark:bg-gray-800/50 dark:text-white dark:border-gray-700/80 focus:ring-2 focus:ring-sky-500 focus:bg-white dark:focus:bg-gray-800 focus:outline-none transition-all duration-200" />
                </div>
              </div>
            </div>

            <!-- Image -->
            <div class="group">
              <label
                class="block text-sm font-medium mb-1.5 text-gray-700 dark:text-gray-300 group-focus-within:text-sky-500 transition-colors">
                Image URL
              </label>
              <div class="relative">
                <span class="absolute left-4 top-3.5 text-gray-400 group-focus-within:text-sky-500 transition-colors">
                  <i data-lucide="image" class="w-5 h-5"></i>
                </span>
                <input type="text" id="prodImage" name="image" value="<%= editing ? product.image : ''%>" required
                  placeholder="https://example.com/..."
                  class="w-full pl-12 pr-4 py-3 rounded-xl border bg-gray-50/50 text-gray-900 border-gray-300/80 dark:bg-gray-800/50 dark:text-white dark:border-gray-700/80 focus:ring-2 focus:ring-sky-500 focus:bg-white dark:focus:bg-gray-800 focus:outline-none transition-all duration-200" />
              </div>
            </div>

            <!-- Description -->
            <div class="group">
              <label
                class="block text-sm font-medium mb-1.5 text-gray-700 dark:text-gray-300 group-focus-within:text-sky-500 transition-colors">
                Description
              </label>
              <div class="relative">
                <textarea rows="4" id="prodDesc" name="description" required
                  placeholder="Describe the highlight features of the product..."
                  class="w-full px-4 py-3 rounded-xl border bg-gray-50/50 text-gray-900 border-gray-300/80 dark:bg-gray-800/50 dark:text-white dark:border-gray-700/80 focus:ring-2 focus:ring-sky-500 focus:bg-white dark:focus:bg-gray-800 focus:outline-none transition-all duration-200 resize-none"><%= editing ? product.description : '' %></textarea>
              </div>
            </div>

            <!-- Buttons -->
            <div class="flex flex-col gap-4 pt-4">
              <button type="submit"
                class="group relative overflow-hidden w-full px-6 py-4 rounded-xl font-bold text-white bg-gradient-to-r from-sky-600 to-indigo-600 hover:from-sky-500 hover:to-indigo-500 active:scale-[0.98] transition-all duration-300 shadow-lg shadow-sky-500/20 hover:shadow-sky-500/40 flex items-center justify-center gap-2">
                <!-- Animated Glow -->
                <span
                  class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>

                <!-- Animated Icon -->
                <i data-lucide="plus-circle" class="relative z-10 w-5 h-5 animate-bounce"></i>

                <span class="relative z-10">
                  <%= editing ? "Update your product" : "List your product" %>
                </span>
              </button>
            </div>
            <a href="#" onclick="window.history.back(); return false;"
              class="group inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-red-600 bg-red-50 border border-red-200 rounded-xl transition-all duration-300 hover:bg-red-100 hover:border-red-300 hover:shadow-lg hover:-translate-y-0.5 dark:bg-red-950/30 dark:border-red-900 dark:text-red-400 dark:hover:bg-red-900/40 active:scale-95">
              <svg xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 transition-transform duration-300 group-hover:-translate-x-2" fill="none"
                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>

              <span>Cancel and go back</span>
            </a>
    </div>
    </div>
    </form>
    </div>
  </main>
  <%- include("../partials/footer") %>