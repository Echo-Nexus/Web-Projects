<%- include("../partials/header") %>
<main class="min-h-screen bg-[#FDFDFD] dark:bg-[#050505] text-gray-900 dark:text-white transition-colors duration-500 py-12 md:py-20 px-4 sm:px-8">
  <div class="max-w-7xl mx-auto">
      <!-- Back Button -->
  <button
    onclick="window.history.back()"
    class="mb-8 inline-flex items-center gap-2 px-5 py-3 rounded-2xl bg-white dark:bg-[#111] border border-gray-200 dark:border-gray-800 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 font-semibold"
  >
    <i data-lucide="arrow-left" class="w-4 h-4"></i>
    Go Back
  </button>
    <section class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
      
      <div class="lg:col-span-7 space-y-6">
        <div class="relative group aspect-square rounded-[32px] overflow-hidden bg-gray-100 dark:bg-[#111] border border-gray-200 dark:border-gray-800 shadow-2xl shadow-gray-200/50 dark:shadow-black/50">
          <img src="<%= product.image %>" alt="<%= product.title %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
          <div class="absolute top-6 left-6">
            <span class="px-4 py-2 bg-white/80 dark:bg-black/60 backdrop-blur-xl rounded-full text-[10px] font-black uppercase tracking-[0.2em] shadow-lg border border-white/20">
              <%= product.badge %>
            </span>
          </div>
        </div>
      </div>

      <div class="lg:col-span-5 flex flex-col justify-center">
        <div class="space-y-6">
          <div class="flex items-center gap-3 text-sm font-medium text-gray-500">
            <span class="flex items-center gap-1"><i data-lucide="tag" class="w-4 h-4"></i> <%= product.category %></span>
            <span class="w-1 h-1 rounded-full bg-gray-300"></span>
            <span class="flex items-center gap-1"><i data-lucide="map-pin" class="w-4 h-4"></i> <%= product.location %></span>
          </div>

          <h1 class="text-4xl md:text-6xl font-extrabold tracking-tighter leading-[0.95]">
            <%= product.title %>
          </h1>

          <div class="flex items-center gap-4">
            <div class="flex items-center gap-1.5 text-amber-500">
              <i data-lucide="star" class="w-5 h-5 fill-current"></i>
              <span class="font-bold text-lg text-gray-900 dark:text-white"><%= product.rating %></span>
            </div>
            <span class="text-gray-400 font-medium underline underline-offset-4"><%= product.reviews %> Reviews</span>
          </div>

          <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
            <%= product.description %>
          </p>

          <div class="py-6 border-y border-gray-200 dark:border-gray-800">
            <span class="text-5xl font-black tracking-tight">$<%= product.price %></span>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <button class="h-16 rounded-2xl bg-black dark:bg-white text-white dark:text-black font-bold flex items-center justify-center gap-2 hover:opacity-80 transition-all active:scale-[0.98]">
              <i data-lucide="shopping-bag" class="w-5 h-5"></i> Add to Cart
            </button>
            <button class="h-16 rounded-2xl bg-gray-100 dark:bg-[#1A1A1A] hover:bg-gray-200 dark:hover:bg-[#222] font-bold transition-all active:scale-[0.98]">
              Buy Now
            </button>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-24 grid grid-cols-2 md:grid-cols-4 gap-8 py-12 border-y border-gray-200 dark:border-gray-800">
      <% const features = [
        { icon: 'truck', text: 'Free Express Shipping' },
        { icon: 'shield-check', text: 'Secure Payments' },
        { icon: 'refresh-ccw', text: 'Easy Returns' },
        { icon: 'award', text: '2-Year Warranty' }
      ]; %>
      <% features.forEach(f => { %>
        <div class="flex items-center gap-3">
          <i data-lucide="<%= f.icon %>" class="w-6 h-6 text-rose-500"></i>
          <span class="font-semibold"><%= f.text %></span>
        </div>
      <% }); %>
    </section>

  </div>
</main>

<script>
  // Initialize Lucide Icons
  lucide.createIcons();
</script>

<%- include("../partials/footer") %>