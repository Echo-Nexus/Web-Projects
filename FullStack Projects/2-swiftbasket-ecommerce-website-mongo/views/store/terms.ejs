          <!-- Section 8 -->
          <div id="contact-legal" class="terms-card bg-white/75 dark:bg-gray-900/40 border border-gray-200/60 dark:border-gray-800/60 backdrop-blur-xl rounded-[32px] p-6 sm:p-10 shadow-xl dark:shadow-black/10 content-section">
            <div class="flex items-center gap-3 mb-4">
              <span class="w-10 h-10 rounded-2xl bg-rose-50 dark:bg-rose-500/10 text-[#FF385C] flex items-center justify-center">
