<%- include("../partials/header") %>
<main class="w-full min-h-screen py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden bg-gray-50 text-[#222222] dark:bg-gray-950 dark:text-zinc-200 transition-colors duration-500 font-['Nunito_Sans',_sans-serif]">
  
  <!-- Embedding Google Font Link dynamically inside the module to preserve self-containment -->
  <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
  <!-- Script for Lucide Icons to execute within preview environments -->
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    /* Premium smooth scale animations for items list */
    .wishlist-item {
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .wishlist-item.removing {
      transform: scale(0.9) translateY(10px);
      opacity: 0;
    }
    /* Layout orientation transitions */
    .view-grid-layout {
      display: grid;
    }
    .view-list-layout {
      display: flex;
      flex-direction: column;
    }
    /* Toast Animation */
    @keyframes slideInUp {
      from { transform: translateY(100px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
    .toast-active {
      animation: slideInUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
  </style>

  <!-- Ambient Glow Background Orbs positioned absolutely inside parent container -->
  <div class="absolute top-10 left-10 w-72 h-72 sm:w-96 sm:h-96 rounded-full bg-rose-400/10 dark:bg-[#FF385C]/5 blur-[120px] pointer-events-none select-none transition-all duration-500"></div>
  <div class="absolute bottom-10 right-10 w-72 h-72 sm:w-96 sm:h-96 rounded-full bg-sky-400/10 dark:bg-sky-500/5 blur-[120px] pointer-events-none select-none transition-all duration-500"></div>

  <!-- Main Responsive Wrapper Container -->
  <div class="max-w-7xl mx-auto relative z-10 space-y-8">
    
    <!-- Top Stats & Controls Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 pb-6 border-b border-gray-200/80 dark:border-zinc-800/80">
      <div class="space-y-2 text-left">
        <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full text-xs font-black uppercase tracking-wider bg-rose-50 text-[#FF385C] dark:bg-[#FF385C]/10 dark:text-[#FF385C]">
          <i data-lucide="heart" class="w-4 h-4 fill-current"></i> Saved Curations
        </span>
        <h1 class="text-3xl sm:text-4xl font-black tracking-tight text-gray-900 dark:text-white">
          My Wishlist
        </h1>
        <p class="text-xs sm:text-sm text-gray-500 dark:text-zinc-400">
          You have <span id="wishlistCountLabel" class="font-extrabold text-gray-900 dark:text-white">0</span> items saved. Total curated value: <span id="wishlistValueLabel" class="font-extrabold text-[#FF385C]">$0.00</span>
        </p>
      </div>

      <!-- Header CTAs -->
      <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
        <button onclick="shareCuratedWishlist()" class="flex-grow md:flex-grow-0 inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-gray-200 hover:border-[#FF385C]/40 dark:border-zinc-800 hover:bg-rose-500/5 text-xs sm:text-sm font-bold transition-all active:scale-95">
          <i data-lucide="share-2" class="w-4.5 h-4.5 text-[#FF385C]"></i>
          <span>Share Wishlist</span>
        </button>
        <button onclick="addAllInStockToCart()" class="flex-grow md:flex-grow-0 inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl bg-[#FF385C] hover:bg-[#e01e43] text-white text-xs sm:text-sm font-black transition-all active:scale-[0.98] shadow-lg shadow-rose-500/15">
          <i data-lucide="shopping-cart" class="w-4.5 h-4.5"></i>
          <span>Add All In Stock to Cart</span>
        </button>
      </div>
    </div>

    <!-- Filter, Search & View Swapper Control Bar -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-white/50 dark:bg-gray-900/20 p-4 border border-gray-200/60 dark:border-gray-800/60 rounded-2xl backdrop-blur-md">
      <!-- Search Input -->
      <div class="relative w-full sm:max-w-xs group">
        <span class="absolute left-3.5 top-3 text-gray-400 group-focus-within:text-[#FF385C] transition-colors">
          <i data-lucide="search" class="w-4 h-4"></i>
        </span>
        <input 
          type="text" 
          id="wishlistSearch" 
          oninput="handleSearchFilter()"
          placeholder="Search wishlist items..."
          class="w-full pl-10 pr-4 py-2 rounded-xl border text-xs sm:text-sm bg-white dark:bg-gray-900 text-gray-900 border-gray-200 dark:text-white dark:border-zinc-800/80 focus:ring-2 focus:ring-[#FF385C] focus:bg-white dark:focus:bg-gray-950 focus:outline-none transition-all duration-300"
        />
      </div>

      <!-- Filters & Layout Toggles -->
      <div class="flex items-center justify-between sm:justify-end gap-4 w-full sm:w-auto">
        <!-- Category Filter Select -->
        <select 
          id="categoryFilter" 
          onchange="handleSearchFilter()"
          class="px-4 py-2 rounded-xl border text-xs sm:text-sm bg-white dark:bg-gray-900 text-gray-900 border-gray-200 dark:text-white dark:border-zinc-800/80 focus:ring-2 focus:ring-[#FF385C] focus:bg-white focus:outline-none transition-all"
        >
          <option value="All">All Categories</option>
          <option value="Electronics">Electronics</option>
          <option value="Accessories">Accessories</option>
          <option value="Workspace">Workspace</option>
          <option value="Lighting">Lighting</option>
        </select>

        <!-- Grid / List Switchers -->
        <div class="flex items-center bg-gray-100 dark:bg-zinc-900 p-1 rounded-xl">
          <button 
            onclick="switchViewMode('grid')" 
            id="viewBtnGrid"
            class="p-1.5 rounded-lg text-gray-500 dark:text-zinc-400 bg-white dark:bg-zinc-800 shadow-sm transition-all"
            title="Grid View"
          >
            <i data-lucide="grid" class="w-4.5 h-4.5 text-[#FF385C]"></i>
          </button>
          <button 
            onclick="switchViewMode('list')" 
            id="viewBtnList"
            class="p-1.5 rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-zinc-200 transition-all"
            title="List View"
          >
            <i data-lucide="list" class="w-4.5 h-4.5"></i>
          </button>
        </div>
      </div>
    </div>

    <!-- Grid/List Main Curated Cards Feed -->
    <div id="wishlistContainer" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Dynamic cards injected here by JS -->
    </div>

    <!-- Fallback Wishlist Empty State -->
    <div id="emptyWishlistState" class="hidden text-center py-16 px-4 max-w-md mx-auto space-y-6">
      <div class="relative w-36 h-36 mx-auto flex items-center justify-center">
        <div class="absolute inset-2 bg-[#FF385C]/10 rounded-full animate-ping"></div>
        <span class="relative w-24 h-24 rounded-full bg-rose-50 dark:bg-rose-500/10 text-[#FF385C] flex items-center justify-center shadow-inner">
          <i data-lucide="heart-off" class="w-12 h-12"></i>
        </span>
      </div>
      <div class="space-y-2">
        <h3 class="text-xl font-black text-gray-900 dark:text-white">Your Wishlist is Empty</h3>
        <p class="text-xs sm:text-sm text-gray-500 dark:text-zinc-400 leading-relaxed">
          Explore our customized trending product catalogs, select items you adore, and build your bespoke shopping curation profiles.
        </p>
      </div>
      <a href="/products" class="inline-flex items-center gap-2 bg-[#FF385C] hover:bg-[#e01e43] text-white font-bold py-3 px-6 rounded-xl text-xs sm:text-sm transition duration-200 active:scale-[0.98]">
        <i data-lucide="shopping-bag" class="w-4 h-4"></i> Continue Shopping
      </a>
    </div>

  </div>

  <!-- Premium Toast Alert Box System -->
  <div id="wishlistToastContainer" class="fixed bottom-6 right-6 z-50 flex flex-col gap-3 pointer-events-none">
    <!-- Active notifications slide into here dynamically -->
  </div>

  <!-- Embedded Modular EJS Javascript Scope -->
  <script>
    (function() {
      // 1. DATA DATABASE SOURCE SEEDING
      const initialWishlistDb = [
        {
          id: "a5d4998e-56bf-4c9c-a578-b27cfc4eebc0",
          title: "AeroSound ANC Headphones",
          category: "Electronics",
          price: 299,
          rating: "4.8",
          stockStatus: "In Stock",
          image: "https://images.unsplash.com/photo-1505740420928-5e560c06d30e?auto=format&fit=crop&w=800&q=80",
          description: "Experience luxury acoustic perfection. Built with robust active noise cancelling (ANC) and deep ergonomic memory foam earcups."
        },
        {
          id: "877b963e-3255-4598-bca9-857d3e1f6c23",
          title: "ChronoX Matte Watch",
          category: "Accessories",
          price: 189,
          rating: "4.9",
          stockStatus: "Only 2 Left",
          image: "https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&w=800&q=80",
          description: "Minimal styling engineered with precise Miyota quartz movement and scratch-resistant sapphire crystal glass."
        },
        {
          id: "5a27d6a4-74f8-441a-968f-045a57a42c78",
          title: "AirSprint Prime Running",
          category: "Footwear",
          price: 120,
          rating: "4.7",
          stockStatus: "Out of Stock",
          image: "https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&w=800&q=80",
          description: "Responsive foam cushioning engineered with recycled materials offering long-lasting durability."
        },
        {
          id: "e4b1752d-c224-4c77-9f77-f13b3dc65e11",
          title: "Zenith Mechanical Keyboard",
          category: "Workspace",
          price: 220,
          rating: "4.9",
          stockStatus: "In Stock",
          image: "https://images.unsplash.com/photo-1587829741301-dc798b83add3?auto=format&fit=crop&w=800&q=80",
          description: "Premium 75% mechanical layout featuring CNC-milled aluminum casing and hot-swappable tactile keys."
        },
        {
          id: "c9a26b3e-7812-4c9c-b578-c27cfc4ee2a2",
          title: "Lumina Brass Desk Lamp",
          category: "Lighting",
          price: 175,
          rating: "4.7",
          stockStatus: "In Stock",
          image: "https://images.unsplash.com/photo-1507473885765-e6ed057f782c?auto=format&fit=crop&w=800&q=80",
          description: "Architectural heavy-gauge brushed brass desk lamp with an adjustable cantilever arm and counterweight balance."
        }
      ];

      // Local State parameters
      let wishlistItems = [...initialWishlistDb];
      let layoutViewMode = 'grid'; // 'grid' | 'list'

      window.addEventListener('DOMContentLoaded', () => {
        if (typeof lucide !== 'undefined') {
          lucide.createIcons();
        }
        updateCountersAndStats();
        renderActiveWishlist();
      });

      // 2. RENDER WIZARD ENGINE
      function renderActiveWishlist() {
        const container = document.getElementById('wishlistContainer');
        const emptyState = document.getElementById('emptyWishlistState');
        const searchVal = document.getElementById('wishlistSearch').value.trim().toLowerCase();
        const catFilter = document.getElementById('categoryFilter').value;

        // Apply Localized search/filter rules
        const filtered = wishlistItems.filter(item => {
          const matchesSearch = item.title.toLowerCase().includes(searchVal) || item.description.toLowerCase().includes(searchVal);
          const matchesCategory = catFilter === 'All' || item.category === catFilter;
          return matchesSearch && matchesCategory;
        });

        // Toggle clean empty state viewport representations
        if (filtered.length === 0) {
          container.classList.add('hidden');
          emptyState.classList.remove('hidden');
          return;
        }

        emptyState.classList.add('hidden');
        container.classList.remove('hidden');

        // Layout wrapper mapping configuration
        if (layoutViewMode === 'grid') {
          container.className = "grid sm:grid-cols-2 lg:grid-cols-3 gap-6";
        } else {
          container.className = "flex flex-col gap-4 w-full";
        }

        container.innerHTML = filtered.map(item => {
          return layoutViewMode === 'grid' 
            ? buildGridCardTemplate(item) 
            : buildListRowTemplate(item);
        }).join('');

        // Re-execute Lucide Icons on matching markup inject
        if (typeof lucide !== 'undefined') {
          lucide.createIcons();
        }
      }

      // Grid Card Representation String Builder
      function buildGridCardTemplate(item) {
        const outOfStock = item.stockStatus === "Out of Stock";
        const stockBadgeColor = outOfStock 
          ? "bg-gray-100 text-gray-500 dark:bg-zinc-800 dark:text-zinc-400" 
          : item.stockStatus.includes("Only") 
            ? "bg-amber-50 text-amber-600 dark:bg-amber-500/10 dark:text-amber-400" 
            : "bg-emerald-50 text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400";

        return `
          <div id="item-card-${item.id}" class="wishlist-item bg-white/70 dark:bg-gray-900/30 border border-gray-200/60 dark:border-gray-800/60 backdrop-blur-md rounded-2xl overflow-hidden hover:shadow-lg hover:border-rose-500/25 flex flex-col group h-full">
            <!-- Product Image Frame -->
            <div class="relative aspect-video w-full overflow-hidden bg-gray-100 dark:bg-zinc-800">
              <img src="${item.image}" alt="${item.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <!-- Absolute Badge overlays -->
              <div class="absolute top-3 left-3 flex flex-wrap gap-1.5">
                <span class="px-2 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider ${stockBadgeColor}">
                  ${item.stockStatus}
                </span>
              </div>
              <button onclick="handleRemoveWishlistItem('${item.id}')" class="absolute top-3 right-3 w-8.5 h-8.5 rounded-full bg-white/90 dark:bg-zinc-900/90 text-gray-400 hover:text-[#FF385C] flex items-center justify-center hover:scale-110 active:scale-95 shadow-md transition-all">
                <i data-lucide="trash-2" class="w-4 h-4"></i>
              </button>
            </div>

            <!-- Content Panel -->
            <div class="p-5 flex flex-col flex-grow justify-between space-y-4">
              <div class="space-y-1.5">
                <div class="flex items-center justify-between text-[11px] font-bold uppercase tracking-wider text-gray-400 dark:text-zinc-500">
                  <span>${item.category}</span>
                  <span class="flex items-center gap-0.5"><i data-lucide="star" class="w-3.5 h-3.5 fill-[#FBBF24] text-[#FBBF24]"></i> ${item.rating}</span>
                </div>
                <h3 class="font-extrabold text-sm sm:text-base text-gray-900 dark:text-white line-clamp-1">${item.title}</h3>
                <p class="text-xs text-gray-500 dark:text-zinc-400 leading-relaxed line-clamp-2">${item.description}</p>
              </div>

              <!-- Action Bar -->
              <div class="flex items-center justify-between pt-3 border-t border-gray-100 dark:border-zinc-800/60">
                <span class="text-lg font-black text-gray-900 dark:text-white">$${item.price}.00</span>
                <button 
                  onclick="handleMoveItemToCart('${item.id}')"
                  ${outOfStock ? 'disabled' : ''}
                  class="px-4 py-2 rounded-xl text-xs font-black flex items-center gap-1.5 transition duration-200 active:scale-95 ${outOfStock ? 'bg-gray-100 dark:bg-zinc-800 text-gray-400 cursor-not-allowed' : 'bg-sky-50 dark:bg-sky-500/10 text-sky-500 hover:bg-sky-500 hover:text-white dark:hover:bg-sky-500 dark:hover:text-white'}"
                >
                  <i data-lucide="shopping-cart" class="w-3.5 h-3.5"></i>
                  <span>${outOfStock ? 'Restocking' : 'Move to Cart'}</span>
                </button>
              </div>
            </div>
          </div>
        `;
      }

      // Streamlined List Row Template String Builder
      function buildListRowTemplate(item) {
        const outOfStock = item.stockStatus === "Out of Stock";
        const stockBadgeColor = outOfStock 
          ? "bg-gray-100 text-gray-500 dark:bg-zinc-800 dark:text-zinc-400" 
          : item.stockStatus.includes("Only") 
            ? "bg-amber-50 text-amber-600 dark:bg-amber-500/10 dark:text-amber-400" 
            : "bg-emerald-50 text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400";

        return `
          <div id="item-card-${item.id}" class="wishlist-item bg-white/70 dark:bg-gray-900/30 border border-gray-200/60 dark:border-gray-800/60 backdrop-blur-md rounded-2xl p-4 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 hover:border-rose-500/25 hover:shadow-md">
            
            <!-- Left Meta Column -->
            <div class="flex items-center gap-4 w-full md:w-auto">
              <div class="w-16 h-16 rounded-xl overflow-hidden bg-gray-100 dark:bg-zinc-800 flex-shrink-0">
                <img src="${item.image}" alt="${item.title}" class="w-full h-full object-cover" />
              </div>
              <div class="space-y-1 text-left">
                <div class="flex items-center gap-2">
                  <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400 dark:text-zinc-500">${item.category}</span>
                  <span class="px-2 py-0.5 rounded-lg text-[9px] font-black uppercase tracking-wider ${stockBadgeColor}">
                    ${item.stockStatus}
                  </span>
                </div>
                <h3 class="font-extrabold text-xs sm:text-sm text-gray-900 dark:text-white">${item.title}</h3>
                <p class="text-xs text-gray-500 dark:text-zinc-400 leading-normal line-clamp-1 md:max-w-md">${item.description}</p>
              </div>
            </div>

            <!-- Right Meta/Actions Column -->
            <div class="flex items-center justify-between md:justify-end gap-6 w-full md:w-auto pt-3 md:pt-0 border-t md:border-t-0 border-gray-100 dark:border-zinc-800/60">
              <div class="text-left md:text-right">
                <span class="text-base sm:text-lg font-black text-gray-900 dark:text-white">$${item.price}.00</span>
                <span class="block text-[10px] text-zinc-400 font-semibold flex items-center justify-start md:justify-end gap-0.5"><i data-lucide="star" class="w-3 h-3 fill-[#FBBF24] text-[#FBBF24]"></i> ${item.rating}</span>
              </div>

              <div class="flex items-center gap-2.5">
                <button 
                  onclick="handleMoveItemToCart('${item.id}')"
                  ${outOfStock ? 'disabled' : ''}
                  class="px-4 py-2.5 rounded-xl text-xs font-black flex items-center gap-1.5 transition duration-200 active:scale-95 ${outOfStock ? 'bg-gray-100 dark:bg-zinc-800 text-gray-400 cursor-not-allowed' : 'bg-sky-50 dark:bg-sky-500/10 text-sky-500 hover:bg-sky-500 hover:text-white dark:hover:bg-sky-500 dark:hover:text-white'}"
                >
                  <i data-lucide="shopping-cart" class="w-3.5 h-3.5"></i>
                  <span>${outOfStock ? 'Restocking' : 'Move to Cart'}</span>
                </button>
                <button onclick="handleRemoveWishlistItem('${item.id}')" class="w-9.5 h-9.5 rounded-xl border border-gray-200 hover:border-[#FF385C]/30 hover:bg-rose-500/5 text-gray-400 hover:text-[#FF385C] flex items-center justify-center transition-all active:scale-95">
                  <i data-lucide="trash-2" class="w-4 h-4"></i>
                </button>
              </div>
            </div>

          </div>
        `;
      }

      // 3. ACTION EVENT LOGIC HANDLERS
      window.handleRemoveWishlistItem = function(id) {
        const itemNode = document.getElementById(`item-card-${id}`);
        if (itemNode) {
          itemNode.classList.add('removing');
        }

        setTimeout(() => {
          const removed = wishlistItems.find(item => item.id === id);
          wishlistItems = wishlistItems.filter(item => item.id !== id);
          
          updateCountersAndStats();
          renderActiveWishlist();
          
          if (removed) {
            pushToastNotification("info", `Removed ${removed.title} from Wishlist.`);
          }
        }, 350);
      };

      window.handleMoveItemToCart = function(id) {
        const itemNode = document.getElementById(`item-card-${id}`);
        const product = wishlistItems.find(item => item.id === id);

        if (!product) return;

        // Apply smooth transition before removal
        if (itemNode) {
          itemNode.classList.add('removing');
        }

        setTimeout(() => {
          // Remove from local wishlist data
          wishlistItems = wishlistItems.filter(item => item.id !== id);

          // Simulate adding to header cart tracker counts
          const headerCartCounter = document.getElementById('cart-counter');
          if (headerCartCounter) {
            let currentCartVal = parseInt(headerCartCounter.textContent) || 0;
            headerCartCounter.textContent = currentCartVal + 1;
            // Pop counter animation class
            headerCartCounter.classList.add('scale-110');
            setTimeout(() => headerCartCounter.classList.remove('scale-110'), 200);
          }

          updateCountersAndStats();
          renderActiveWishlist();
          
          pushToastNotification("success", `Moved ${product.title} directly to checkout shopping cart.`);
        }, 350);
      };

      window.addAllInStockToCart = function() {
        const inStockItems = wishlistItems.filter(item => item.stockStatus !== "Out of Stock");

        if (inStockItems.length === 0) {
          pushToastNotification("error", "No available instock items left inside your wishlist curate profile.");
          return;
        }

        inStockItems.forEach(item => {
          // Trigger dynamic cart index animations for each item
          const itemNode = document.getElementById(`item-card-${item.id}`);
          if (itemNode) {
            itemNode.classList.add('removing');
          }
        });

        setTimeout(() => {
          const count = inStockItems.length;
          wishlistItems = wishlistItems.filter(item => item.stockStatus === "Out of Stock");

          // Update header counters directly
          const headerCartCounter = document.getElementById('cart-counter');
          if (headerCartCounter) {
            let currentCartVal = parseInt(headerCartCounter.textContent) || 0;
            headerCartCounter.textContent = currentCartVal + count;
          }

          updateCountersAndStats();
          renderActiveWishlist();

          pushToastNotification("success", `Successfully moved ${count} in-stock curations over to your active cart.`);
        }, 400);
      };

      // 4. STATS & COMPOSITIONAL UPDATERS
      function updateCountersAndStats() {
        const totalCount = wishlistItems.length;
        const totalVal = wishlistItems.reduce((acc, current) => acc + current.price, 0);

        // Update header counter natively if exists in scope
        const headerWishlistCounter = document.getElementById('wishlist-counter');
        if (headerWishlistCounter) {
          headerWishlistCounter.textContent = totalCount;
        }

        // Update in-page counter metadata labels
        const label = document.getElementById('wishlistCountLabel');
        const valueLabel = document.getElementById('wishlistValueLabel');
        
        if (label) label.textContent = totalCount;
        if (valueLabel) valueLabel.textContent = `$${totalVal.toFixed(2)}`;
      }

      window.handleSearchFilter = function() {
        renderActiveWishlist();
      };

      window.switchViewMode = function(mode) {
        layoutViewMode = mode;
        const btnGrid = document.getElementById('viewBtnGrid');
        const btnList = document.getElementById('viewBtnList');

        if (mode === 'grid') {
          btnGrid.className = "p-1.5 rounded-lg text-gray-500 dark:text-zinc-400 bg-white dark:bg-zinc-800 shadow-sm transition-all";
          btnList.className = "p-1.5 rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-zinc-200 transition-all";
        } else {
          btnList.className = "p-1.5 rounded-lg text-gray-500 dark:text-zinc-400 bg-white dark:bg-zinc-800 shadow-sm transition-all";
          btnGrid.className = "p-1.5 rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-zinc-200 transition-all";
        }

        renderActiveWishlist();
      };

      // 5. TOAST NOTIFICATIONS & SHARE HOOKS
      window.shareCuratedWishlist = function() {
        const mockUrl = `${window.location.origin}/wishlist/share/SB-${Math.floor(100000 + Math.random() * 900000)}`;
        
        // Custom executive copy code fallback
        const dummyInput = document.createElement('input');
        document.body.appendChild(dummyInput);
        dummyInput.value = mockUrl;
        dummyInput.select();
        document.execCommand('copy');
        document.body.removeChild(dummyInput);

        pushToastNotification("success", "Shareable wishlist reference link successfully copied to your clipboard!");
      };

      function pushToastNotification(type, message) {
        const container = document.getElementById('wishlistToastContainer');
        if (!container) return;

        // Custom icon mapping
        let iconMarkup = `<i data-lucide="info" class="w-5 h-5 text-sky-500"></i>`;
        let borderAndBg = "bg-white dark:bg-zinc-900 border-zinc-200 dark:border-zinc-800";

        if (type === "success") {
          iconMarkup = `<i data-lucide="check-circle-2" class="w-5 h-5 text-emerald-500"></i>`;
        } else if (type === "error") {
          iconMarkup = `<i data-lucide="alert-triangle" class="w-5 h-5 text-rose-500"></i>`;
        }

        const toast = document.createElement('div');
        toast.className = `toast-active pointer-events-auto flex items-center gap-3.5 px-4.5 py-3.5 rounded-2xl border shadow-xl ${borderAndBg} max-w-sm transition-all`;
        toast.innerHTML = `
          <span class="flex-shrink-0">${iconMarkup}</span>
          <p class="text-xs font-bold text-gray-700 dark:text-zinc-300 leading-normal">${message}</p>
        `;

        container.appendChild(toast);
        if (typeof lucide !== 'undefined') {
          lucide.createIcons();
        }

        // Slide away with smooth scale fade transitions
        setTimeout(() => {
          toast.style.transform = "translateY(20px) scale(0.9)";
          toast.style.opacity = "0";
          setTimeout(() => toast.remove(), 400);
        }, 4000);
      }

    })();
  </script>
</main>
