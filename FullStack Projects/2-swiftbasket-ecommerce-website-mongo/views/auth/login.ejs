<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LOGIN</title>
  <link rel="icon" href="https://images.unsplash.com/vector-1780599883133-df4851a972f2?q=80&w=880&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" type="image/svg+xml" />
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Google Fonts (Plus Jakarta Sans for premium modern look) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=300;400;500;600;700&display=swap"
    rel="stylesheet" />
  <!-- FontAwesome for eye-catching UI icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <style>
    body {
      font-family: "Plus Jakarta Sans", sans-serif;
    }

    /* Custom animated gradient background */
    .animated-bg {
      background: linear-gradient(-45deg, #0f172a, #1e1b4b, #311042, #0f172a);
      background-size: 400% 400%;
      animation: gradient 15s ease infinite;
    }

    @keyframes gradient {
      0% {
        background-position: 0% 50%;
      }

      50% {
        background-position: 100% 50%;
      }

      100% {
        background-position: 0% 50%;
      }
    }
  </style>
</head>

<body class="animated-bg min-h-screen flex items-center justify-center p-4 sm:p-6 overflow-x-hidden">
  <!-- Decorative background blobs -->
  <div
    class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-72 h-72 sm:w-96 sm:h-96 bg-indigo-500 rounded-full mix-blend-screen filter blur-[80px] opacity-20 pointer-events-none">
  </div>
  <div
    class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-72 h-72 sm:w-96 sm:h-96 bg-fuchsia-500 rounded-full mix-blend-screen filter blur-[80px] opacity-20 pointer-events-none">
  </div>

  <!-- Main Container -->
  <div
    class="relative w-full max-w-md bg-slate-900/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 sm:p-10 shadow-2xl transition-all duration-300 hover:border-indigo-500/30">
    <!-- Logo / Branding Area -->
    <div class="text-center mb-8">
      <div
        class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-gradient-to-tr from-indigo-500 to-fuchsia-500 p-[1.5px] shadow-lg shadow-indigo-500/20 mb-4">
        <div class="w-full h-full bg-slate-950 rounded-[10px] flex items-center justify-center">
          <i
            class="fa-solid fa-shield-halved text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-fuchsia-400 text-2xl"></i>
        </div>
      </div>
      <h1 class="text-2xl sm:text-3xl font-bold text-white tracking-tight">
        Welcome Back
      </h1>
      <p class="text-slate-400 text-sm mt-2">
        Sign in to access your dashboard
      </p>
    </div>

    <!-- Notification Alerts (Hidden by default, toggle with CSS framework or JS) -->
    <div id="errorAlert"
      class="hidden mb-6 p-4 rounded-xl bg-red-500/10 border border-red-500/30 flex items-start gap-3 animate-pulse">
      <i class="fa-solid fa-circle-exclamation text-red-400 mt-0.5"></i>
      <div class="text-sm text-red-200" id="errorText">
        Invalid email or password. Please try again.
      </div>
    </div>

    <div id="successAlert"
      class="hidden mb-6 p-4 rounded-xl bg-emerald-500/10 border border-emerald-500/30 flex items-start gap-3">
      <i class="fa-solid fa-circle-check text-emerald-400 mt-0.5"></i>
      <div class="text-sm text-emerald-200" id="successText">
        Login successful! Redirecting...
      </div>
    </div>
    <!-- Notification Alerts (For Server-Side Rendering Support if needed) -->
    <% if (errors && errors.length) { %>
      <div class="mb-6 p-4 rounded-xl bg-red-500/10 border border-red-500/30 flex items-start gap-3">
        <i class="fa-solid fa-circle-exclamation text-red-400 mt-0.5"></i>

        <ul class="text-sm text-red-200 space-y-1">
          <% errors.forEach(error=> { %>
            <li>
              <%= error %>
            </li>
            <% }) %>
        </ul>
      </div>
      <% } %>

        <!-- Login Form -->
        <form action="/auth/login" method="POST" class="space-y-6">
          <!-- Email Field -->
          <div>
            <label for="email" class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-2">Email
              Address</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-500">
                <i class="fa-regular fa-envelope text-lg"></i>
              </div>
              <input type="email" name="email" id="email" required placeholder="you@example.com" value="<%= oldInput.email ? oldInput.email : ''%>"
                class="w-full pl-11 pr-4 py-3 bg-slate-950/50 border border-slate-700/60 rounded-xl text-slate-200 placeholder-slate-500 outline-none transition-all duration-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:bg-slate-950" />
            </div>
          </div>

          <!-- Password Field -->
          <div>
            <div class="flex justify-between items-center mb-2">
              <label for="password"
                class="block text-xs font-semibold text-slate-300 uppercase tracking-wider">Password</label>
              <a href="/forgot-password"
                class="text-xs font-medium text-indigo-400 hover:text-indigo-300 transition-colors">Forgot password?</a>
            </div>
            <div class="relative" id="passwordContainer">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-500">
                <i class="fa-solid fa-lock text-lg"></i>
              </div>
              <input type="password" name="password" id="password" required placeholder="••••••••"
                class="w-full pl-11 pr-11 py-3 bg-slate-950/50 border border-slate-700/60 rounded-xl text-slate-200 placeholder-slate-500 outline-none transition-all duration-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:bg-slate-950" />
              <!-- Toggle Visibility Button -->
              <button type="button" id="togglePassword"
                class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-slate-500 hover:text-slate-300 transition-colors"
                aria-label="Toggle password visibility">
                <i class="fa-regular fa-eye text-lg" id="eyeIcon"></i>
              </button>
            </div>
          </div>
          <!-- Submit Button -->
          <button type="submit"
            class="w-full relative group overflow-hidden rounded-xl p-[1px] focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-slate-900 transition-all duration-300">
            <span
              class="absolute inset-0 bg-gradient-to-r from-indigo-500 via-purple-500 to-fuchsia-500 rounded-xl transition-all duration-300 group-hover:opacity-90"></span>
            <span
              class="relative block px-8 py-3.5 bg-slate-950/20 text-white font-semibold text-center rounded-[11px] transition-all duration-300 group-hover:bg-transparent">
              Sign In
            </span>
          </button>
        </form>
        <div class="text-center mt-6">
          <p class="text-slate-400 text-xs">
            Don't have an account?
            <a href="/auth/signup" class="text-indigo-400 hover:text-indigo-300 font-semibold transition-colors">Sign
              Up</a>
          </p>
        </div>
  </div>

  <!-- Interactive Logic (Toggle visibility) -->
  <script>
    const togglePassword = document.getElementById("togglePassword");
    const passwordInput = document.getElementById("password");
    const eyeIcon = document.getElementById("eyeIcon");

    togglePassword.addEventListener("click", function () {
      const isPassword = passwordInput.getAttribute("type") === "password";
      passwordInput.setAttribute("type", isPassword ? "text" : "password");

      // Toggle eye icon class
      if (isPassword) {
        eyeIcon.classList.remove("fa-regular", "fa-eye");
        eyeIcon.classList.add("fa-solid", "fa-eye-slash");
      } else {
        eyeIcon.classList.remove("fa-solid", "fa-eye-slash");
        eyeIcon.classList.add("fa-regular", "fa-eye");
      }
    });
  </script>
</body>

</html>
