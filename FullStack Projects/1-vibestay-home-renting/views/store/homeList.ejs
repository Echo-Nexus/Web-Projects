<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>VIBESTAY | Premium Homes For You</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700;800;900&display=swap"
    rel="stylesheet" />
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: { sans: ['"Nunito Sans"', "sans-serif"] },
          colors: {
            brand: {
              DEFAULT: "#FF385C",
              hover: "#E31C5F",
              light: "#FFF0F2",
              dark: "#2D1217"
            },
            dark: "#121212"
          },
          screens: {
            'xs': '375px',
          }
        },
      },
    };
  </script>
  <script>
    if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  </script>
  <style>
    /* Smooth custom scrollbars */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    ::-webkit-scrollbar-track {
      background: transparent;
    }

    .dark ::-webkit-scrollbar-thumb {
      background: #2D2D30;
      border-radius: 9999px;
    }

    ::-webkit-scrollbar-thumb {
      background: #E4E4E7;
      border-radius: 9999px;
    }

    /* Hide default scrollbars for smooth categories track */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }

    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>
</head>

<body
  class="bg-gray-50 text-zinc-800 dark:bg-[#0C0C0E] dark:text-zinc-200 antialiased transition-colors duration-300 min-h-screen flex flex-col">

  <header
    class="sticky top-0 z-50 bg-white/80 dark:bg-[#121214]/80 backdrop-blur-md border-b border-gray-200/60 dark:border-zinc-800/60 transition-colors duration-300">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3.5 flex justify-between items-center gap-4">

      <!-- Custom Brand Logo (VibeStay) -->
      <a href="/" class="focus:outline-none focus:ring-2 focus:ring-brand/40 rounded-lg p-1">
        <div
          class="text-brand font-black text-xl sm:text-2xl tracking-tighter flex items-center gap-1.5 sm:gap-2 cursor-pointer select-none shrink-0">
          <svg class="h-7 w-7 sm:h-8 sm:w-8 text-brand shrink-0" viewBox="0 0 100 100" fill="none"
            xmlns="http://www.w3.org/2000/svg">
            <path d="M15 25L50 85L85 25" stroke="currentColor" stroke-width="13" stroke-linecap="round"
              stroke-linejoin="round" />
            <path d="M35 25L50 55L65 25" stroke="currentColor" stroke-width="9" stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>
          <span class="font-extrabold text-xl sm:text-2xl tracking-tight text-zinc-900 dark:text-white">vibestay</span>
        </div>
      </a>

      <!-- Premium Compact Search Bar -->
      <div
        class="hidden md:flex items-center border border-gray-200/80 dark:border-zinc-800 rounded-full shadow-sm hover:shadow-md hover:border-gray-300 dark:hover:border-zinc-700 transition duration-200 cursor-pointer p-1.5 pl-6 gap-3 bg-white dark:bg-[#161619] shrink-0">
        <span class="font-bold text-xs tracking-wide text-zinc-800 dark:text-zinc-200">Anywhere</span>
        <span class="text-gray-300 dark:text-zinc-700">|</span>
        <span class="font-bold text-xs tracking-wide text-zinc-800 dark:text-zinc-200">Any week</span>
        <span class="text-gray-300 dark:text-zinc-700">|</span>
        <span class="text-gray-400 dark:text-zinc-500 text-xs px-2">Add guests</span>
        <div class="bg-brand text-white p-2.5 rounded-full shadow-sm hover:bg-brand-hover transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24"
            stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>

      <!-- Header End Controls -->
      <div class="flex items-center gap-2 sm:gap-4 shrink-0">
        <!-- Modern Theme Toggle Button -->
        <button id="theme-toggle"
          class="p-2.5 rounded-full border border-gray-200 dark:border-zinc-800 hover:bg-gray-100 dark:hover:bg-zinc-800/80 text-zinc-500 dark:text-zinc-400 transition-all active:scale-95"
          aria-label="Toggle Theme">
          <svg id="theme-toggle-sun" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
            stroke-width="2.2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <svg id="theme-toggle-moon" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
            stroke-width="2.2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <!-- Dropdown Menu Switcher -->
        <div class="relative">
          <button id="menu-button"
            class="border border-gray-200 dark:border-zinc-800 bg-white dark:bg-[#161619] rounded-full py-1.5 px-2 sm:py-2 sm:px-3 hover:shadow-md transition-all flex items-center gap-2.5 sm:gap-3 focus:outline-none focus:ring-2 focus:ring-brand/40">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-zinc-500 dark:text-zinc-400" fill="none"
              viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <div
              class="bg-zinc-800 dark:bg-zinc-700 rounded-full w-6 h-6 flex items-center justify-center text-white text-[10px] sm:text-xs font-bold ring-2 ring-gray-100 dark:ring-zinc-800">
              U
            </div>
          </button>

          <!-- Dropdown Menu Options -->
          <div id="menu-dropdown"
            class="hidden absolute right-0 mt-2.5 w-52 sm:w-60 bg-white dark:bg-[#161619] border border-gray-100 dark:border-zinc-800/80 rounded-2xl shadow-xl py-2 z-50 transition-all">
            <a href="/host"
              class="block px-4 py-2.5 text-sm font-bold text-zinc-900 dark:text-white hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition">Become
              a host</a>
            <hr class="border-gray-100 dark:border-zinc-800 my-1" />
            <a href="/"
              class="block px-4 py-2 text-sm text-zinc-600 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition">Home</a>
            <a href="/host/host-home-list"
              class="block px-4 py-2 text-sm text-zinc-600 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition">Host
              Home Lists</a>
            <a href="/bookings"
              class="block px-4 py-2 text-sm text-zinc-600 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition">Bookings</a>
            <a href="/favourite-list"
              class="block px-4 py-2 text-sm text-zinc-600 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition">Favourite
              List</a>
            <a href="/reserve"
              class="block px-4 py-2 text-sm text-zinc-600 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition">Reserve</a>
            <hr class="border-gray-100 dark:border-zinc-800 my-1" />
            <a href="/sign-up"
              class="block px-4 py-2 text-sm text-zinc-600 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition">Sign
              up</a>
            <a href="/log-in"
              class="block px-4 py-2 text-sm text-zinc-600 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition">Log
              in</a>
            <hr class="border-gray-100 dark:border-zinc-800 my-1" />
            <a href="/help-center"
              class="block px-4 py-2 text-sm text-zinc-500 dark:text-zinc-400 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition">Help
              Center</a>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <div
    class="bg-white dark:bg-[#121214] border-b border-gray-100 dark:border-zinc-800 py-3 transition-colors duration-300">
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between gap-6 overflow-x-auto no-scrollbar">
      <div class="flex items-center gap-8 md:gap-10">
        <button
          class="flex flex-col items-center gap-1.5 group border-b-2 border-zinc-900 dark:border-white pb-1.5 transition shrink-0">
          <svg class="h-6 w-6 text-zinc-900 dark:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"
            stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          <span class="text-[11px] font-bold tracking-wide text-zinc-900 dark:text-white">All Stays</span>
        </button>

        <button
          class="flex flex-col items-center gap-1.5 group border-b-2 border-transparent pb-1.5 hover:border-zinc-300 dark:hover:border-zinc-700 transition shrink-0">
          <svg class="h-6 w-6 text-zinc-400 group-hover:text-zinc-600 dark:group-hover:text-zinc-300" fill="none"
            viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          <span
            class="text-[11px] font-semibold text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-800 dark:group-hover:text-zinc-200">Cabins</span>
        </button>

        <button
          class="flex flex-col items-center gap-1.5 group border-b-2 border-transparent pb-1.5 hover:border-zinc-300 dark:hover:border-zinc-700 transition shrink-0">
          <svg class="h-6 w-6 text-zinc-400 group-hover:text-zinc-600 dark:group-hover:text-zinc-300" fill="none"
            viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          <span
            class="text-[11px] font-semibold text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-800 dark:group-hover:text-zinc-200">Trending</span>
        </button>

        <button
          class="flex flex-col items-center gap-1.5 group border-b-2 border-transparent pb-1.5 hover:border-zinc-300 dark:hover:border-zinc-700 transition shrink-0">
          <svg class="h-6 w-6 text-zinc-400 group-hover:text-zinc-600 dark:group-hover:text-zinc-300" fill="none"
            viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
          <span
            class="text-[11px] font-semibold text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-800 dark:group-hover:text-zinc-200">Desert</span>
        </button>

        <button
          class="flex flex-col items-center gap-1.5 group border-b-2 border-transparent pb-1.5 hover:border-zinc-300 dark:hover:border-zinc-700 transition shrink-0">
          <svg class="h-6 w-6 text-zinc-400 group-hover:text-zinc-600 dark:group-hover:text-zinc-300" fill="none"
            viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 002 2h1.5A2.5 2.5 0 0019 9.5V8a2 2 0 00-2-2h-3.17M12 21a9 9 0 100-18 9 9 0 000 18z" />
          </svg>
          <span
            class="text-[11px] font-semibold text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-800 dark:group-hover:text-zinc-200">Islands</span>
        </button>

        <button
          class="flex flex-col items-center gap-1.5 group border-b-2 border-transparent pb-1.5 hover:border-zinc-300 dark:hover:border-zinc-700 transition shrink-0">
          <svg class="h-6 w-6 text-zinc-400 group-hover:text-zinc-600 dark:group-hover:text-zinc-300" fill="none"
            viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
          </svg>
          <span
            class="text-[11px] font-semibold text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-800 dark:group-hover:text-zinc-200">Luxe</span>
        </button>
      </div>

      <div class="hidden sm:flex items-center gap-3">
        <button
          class="flex items-center gap-2 border border-gray-200 dark:border-zinc-800 hover:border-gray-300 dark:hover:border-zinc-700 px-3.5 py-2 rounded-xl bg-white dark:bg-[#161619] transition text-xs font-bold tracking-wide shadow-sm">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
          </svg>
          Filters
        </button>
      </div>
    </div>
  </div>

  <!-- Main Content Layout -->
  <main class="py-8 sm:py-12 px-4 sm:px-6 lg:px-8 flex-1">
    <div class="max-w-7xl mx-auto">

      <!-- Stays Page Header -->
      <div class="mb-8 sm:mb-10 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div class="text-left">
          <h1 class="text-2xl sm:text-3xl font-extrabold text-zinc-900 dark:text-white tracking-tight">Stays for you
          </h1>
          <p class="text-gray-500 dark:text-zinc-400 mt-1 text-sm sm:text-base">Explore top-rated luxury spots across
            the globe.</p>
        </div>
        <p class="text-xs sm:text-sm font-bold text-zinc-500 dark:text-zinc-400">Showing all premium results</p>
      </div>

      <!-- Clean Grid Layout containing modern property cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
        <% homes.forEach(home=> { %>
          <div
            class="group flex flex-col justify-between h-full bg-white dark:bg-[#141416]/50 rounded-3xl overflow-hidden border border-gray-100 dark:border-zinc-900/60 shadow-sm hover:shadow-xl dark:hover:shadow-black/25 transition-all duration-300 relative">

            <!-- Card Image Container -->
            <div class="relative w-full aspect-[4/3] overflow-hidden bg-gray-100 dark:bg-zinc-800">
              <a href="/home-list/home-details/<%= home._id %>" class="block focus:outline-none group/card">
                <img src="<%= home.image %>" alt="<%= home.homeName %>"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out" />

                <!-- Category Tag Overlay -->
                <div
                  class="absolute bottom-3 left-3 bg-black/60 backdrop-blur-md px-2.5 py-1 rounded-md text-[10px] font-black uppercase tracking-wider text-white">
                  Exclusive stay
                </div>
            </div>

            <!-- Card Details Block -->
            <div class="p-5 flex-1 flex flex-col justify-between">
              <div class="flex items-center justify-between gap-2 mb-1.5">
                <h2
                  class="text-sm sm:text-base font-extrabold text-zinc-900 dark:text-white group-hover/card:text-brand transition-colors truncate">
                  <%= home.homeName %>
                </h2>
                <!-- Rating Badge -->
                <div class="flex items-center gap-1 text-xs shrink-0 font-bold text-zinc-900 dark:text-white">
                  <svg class="h-3.5 w-3.5 text-amber-400 fill-current" viewBox="0 0 24 24">
                    <path
                      d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                  </svg>
                  4.9
                </div>
              </div>

              <p class="text-gray-500 dark:text-zinc-400 text-xs sm:text-sm font-semibold flex items-center gap-1">
                <svg class="h-3.5 w-3.5 text-zinc-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                  stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <%= home.location %>
              </p>

              <p class="text-zinc-400 dark:text-zinc-500 text-xs mt-2.5 line-clamp-2 leading-relaxed min-h-[2.2rem]">
                <%= home.description %>
              </p>
              </a>

              <!-- Compact Pricing and Book Button Row -->
              <div
                class="mt-4 pt-4 border-t border-gray-100 dark:border-zinc-800/80 flex items-center justify-between gap-2">
                <div class="flex flex-col">
                  <span class="text-[9px] text-zinc-400 dark:text-zinc-500 font-bold tracking-wider uppercase">Price /
                    Night</span>
                  <span class="font-extrabold text-base sm:text-lg text-zinc-900 dark:text-white leading-none">
                    NRs <%= home.price %>
                  </span>
                </div>

                <!-- Sleek & Small Book Button -->
                <button onclick="window.location.href='/reserve?id=<%= home._id %>'"
                  class="bg-brand hover:bg-brand-hover text-white font-bold py-2 px-3.5 rounded-xl flex items-center justify-center gap-1.5 transition-all duration-150 active:scale-[0.96] hover:shadow-lg hover:shadow-brand/20 dark:hover:shadow-none focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2 dark:focus:ring-offset-[#121214] text-xs sm:text-sm select-none shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round"
                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span>Book</span>
                </button>
              </div>

            </div>
          </div>
          <% }) %>
      </div>

    </div>
  </main>

  <footer
    class="bg-white dark:bg-[#121214] border-t border-gray-200/60 dark:border-zinc-900/60 py-6 sm:py-8 mt-auto transition-colors duration-300">
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-4 text-xs sm:text-sm text-zinc-500 dark:text-zinc-400">
      <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2">
        <span class="font-bold text-zinc-800 dark:text-zinc-200">© 2026 VibeStay, Inc.</span>
        <span>•</span>
        <a href="/privacy" class="hover:underline">Privacy</a>
        <span>•</span>
        <a href="/terms" class="hover:underline">Terms</a>
        <span>•</span>
        <a href="/sitemap" class="hover:underline">Sitemap</a>
      </div>
      <div class="flex items-center gap-4">
        <button class="flex items-center gap-1.5 hover:underline font-bold text-zinc-700 dark:text-zinc-300">
          <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9h18" />
          </svg>
          English (US)
        </button>
        <button class="hover:underline font-bold text-zinc-700 dark:text-zinc-300">$ USD</button>
      </div>
    </div>
  </footer>

  <!-- JavaScript Interactions -->
  <script>
    // Menu Toggle Logic
    const menuButton = document.getElementById('menu-button');
    const menuDropdown = document.getElementById('menu-dropdown');

    menuButton.addEventListener('click', (e) => {
      e.stopPropagation();
      menuDropdown.classList.toggle('hidden');
    });

    document.addEventListener('click', () => {
      menuDropdown.classList.add('hidden');
    });

    // Dark Mode Toggle Switch & Local Storage State Management
    const themeToggleBtn = document.getElementById('theme-toggle');
    const sunIcon = document.getElementById('theme-toggle-sun');
    const moonIcon = document.getElementById('theme-toggle-moon');

    // Sync toggle icons to current theme on load
    if (document.documentElement.classList.contains('dark')) {
      sunIcon.classList.remove('hidden');
    } else {
      moonIcon.classList.remove('hidden');
    }

    themeToggleBtn.addEventListener('click', function () {
      sunIcon.classList.toggle('hidden');
      moonIcon.classList.toggle('hidden');

      if (document.documentElement.classList.contains('dark')) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('color-theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('color-theme', 'dark');
      }
    });

    // Persistent Local Storage Favourites System
    function initFavorites() {
      const favorites = JSON.parse(localStorage.getItem('vibestay_favorites') || '[]');
      document.querySelectorAll('[data-fav-id]').forEach(btn => {
        const id = btn.getAttribute('data-fav-id');
        if (favorites.includes(id)) {
          setFavoriteStyle(btn, true);
        }
      });
    }

    function toggleFavorite(btn, id) {
      let favorites = JSON.parse(localStorage.getItem('vibestay_favorites') || '[]');
      const index = favorites.indexOf(id);
      let isFav = false;
      if (index === -1) {
        favorites.push(id);
        isFav = true;
      } else {
        favorites.splice(index, 1);
      }
      localStorage.setItem('vibestay_favorites', JSON.stringify(favorites));
      setFavoriteStyle(btn, isFav);
    }

    function setFavoriteStyle(btn, isFav) {
      const svg = btn.querySelector('svg');
      if (isFav) {
        svg.classList.add('fill-brand', 'text-brand');
        svg.classList.remove('fill-none', 'text-zinc-400', 'dark:text-zinc-400');
        btn.classList.add('scale-110');
      } else {
        svg.classList.remove('fill-brand', 'text-brand');
        svg.classList.add('fill-none', 'text-zinc-400', 'dark:text-zinc-400');
        btn.classList.remove('scale-110');
      }
    }

    // Run favorite initialization on load
    window.addEventListener('DOMContentLoaded', initFavorites);
  </script>
</body>

</html>