            <li>
              <a href="/trust-and-safety"
                class="text-gray-500 dark:text-gray-400 hover:text-brand dark:hover:text-white transition">Trust &
                Safety</a>
            </li>
            <li>
              <a href="/help-center"
                class="text-gray-500 dark:text-gray-400 hover:text-brand dark:hover:text-white transition">Help Center
                FAQ</a>
            </li>
          </ul>
        </div>

        <!-- Column 4: Newsletter widget -->
        <div class="space-y-4 text-left">
          <h4 class="text-xs font-black uppercase tracking-widest text-dark dark:text-white">
            Subscribe for Deals
          </h4>
          <p class="text-xs text-gray-500 dark:text-gray-400">
            Join our club to get secret discounts up to 40% off.
          </p>
          <form action="/newsletter-signup" method="POST" class="flex gap-2">
            <input type="email" placeholder="Your email address" required
              class="w-full text-xs px-3.5 py-2.5 rounded-xl bg-white dark:bg-zinc-800 border border-gray-200 dark:border-zinc-700 outline-none focus:border-brand dark:focus:border-brand" />
            <button type="submit" class="bg-brand hover:bg-[#E31C5F] text-white p-2.5 rounded-xl transition">
              <svg class="h-4.5 w-4.5 transform rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
            </button>
          </form>
        </div>
      </div>

      <hr class="border-gray-200 dark:border-zinc-800 my-8" />

      <!-- Bottom bar -->
      <div
        class="flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-gray-500 dark:text-gray-400">
        <p>
          © <span id="current-year">2026</span> VibeStay Inc. All premium
          rights reserved.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/privacy-policy" class="hover:text-brand transition">Privacy Policy</a>
          <span>•</span>
          <a href="/terms-of-service" class="hover:text-brand transition">Terms of Service</a>
          <span>•</span>
          <a href="/site-map" class="hover:text-brand transition">Sitemap</a>
        </div>
