  </footer>

  <!-- JavaScript Navigation, Database & Component Interaction Modules -->
  <script>
    // Strictly limited to 3 stays representing Trending, Classic Dorm, and Villa categories
    const propertiesDb = [
      {
        id: "stay-trending",
        category: "Trending",
        categoryClass: "bg-brand/10 text-brand",
        name: "Aura Glass Dome Resort",
        location: "Reykjavik, Iceland",
        description:
          "Sleep under the spectacular dancing Aurora Borealis inside this luxury custom geometric glass dome. Fully climate-controlled with natural hot geothermal springs flowing directly inside.",
        price: 290,
        image:
          "https://images.unsplash.com/photo-1510312305653-8ed496efae75?auto=format&fit=crop&q=80&w=600",
      },
      {
        id: "stay-classic",
        category: "Classic Dorm",
        categoryClass: "bg-teal-500/10 text-teal-600 dark:text-teal-400",
        name: "Minimalist Forest Loft",
        location: "Kyoto, Japan",
        description:
          "Tucked inside a tranquil bamboo forest. This classic architectural dormitory-style loft features shared workspace rooms, authentic cedar wood accents, and tatami floor social areas.",
        price: 185,
        image:
          "https://images.unsplash.com/photo-1508333706533-1ab43ecb1606?auto=format&fit=crop&q=80&w=600",
      },
      {
        id: "stay-villa",
        category: "Villa",
        categoryClass: "bg-amber-500/10 text-amber-600 dark:text-amber-400",
        name: "Sienna Terracotta Villa",
        location: "Tuscany, Italy",
        description:
          "Escape to historic Italian hillsides in this private classical villa, outfitted with terracotta tile roofs, original fireplace brickwork, vineyard terraces, and an infinity overlook pool.",
        price: 340,
        image:
          "https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=80&w=600",
      },
    ];

    // Session Management Elements
    let selectedProperty = null;
    let numberOfGuests = 1;

    // Platform View Outlets
    const homeView = document.getElementById("view-home");
    const heroBanner = document.getElementById("hero-banner");
    const reserveView = document.getElementById("view-reserve");
    const successView = document.getElementById("view-success");
    const staysGrid = document.getElementById("stays-grid");
    const backToHomeBtn = document.getElementById("back-to-home");

    // Form Elements Outlets
    const checkInInput = document.getElementById("check-in");
    const checkOutInput = document.getElementById("check-out");

    // Guest Picker Outlets
    const guestVal = document.getElementById("guest-val");
    const guestInc = document.getElementById("guest-inc");
    const guestDec = document.getElementById("guest-dec");
    const guestSummaryLabel = document.getElementById("guest-count-summary");

    // Receipt Calculator Outlets
    const summaryImg = document.getElementById("summary-img");
    const summaryName = document.getElementById("summary-name");
    const summaryLoc = document.getElementById("summary-loc");
    const summaryCat = document.getElementById("summary-cat");
    const labelNights = document.getElementById("label-nights");
    const calcNights = document.getElementById("calc-nights");
    const calcService = document.getElementById("calc-service");
    const calcTax = document.getElementById("calc-tax");
    const calcTotal = document.getElementById("calc-total");

    // Transaction Action Outlet
    const confirmBookingBtn = document.getElementById("confirm-booking-btn");

    // Invoice Confirmation Outlets
    const receiptRef = document.getElementById("receipt-ref");
    const receiptName = document.getElementById("receipt-name");
    const receiptDates = document.getElementById("receipt-dates");
    const receiptTotal = document.getElementById("receipt-total");

    // Setting date pickers values range to Today and Day After tomorrow
    const today = new Date();
    const inTwoDays = new Date();
    inTwoDays.setDate(today.getDate() + 2);

    checkInInput.value = today.toISOString().split("T")[0];
    checkOutInput.value = inTwoDays.toISOString().split("T")[0];

    // Render catalog grid containing exactly the three customized categorised items
    function renderCuratedCatalog() {
      staysGrid.innerHTML = "";
      propertiesDb.forEach((property) => {
        const card = document.createElement("div");
        card.className =
          "group cursor-pointer flex flex-col justify-between h-full bg-white dark:bg-zinc-800/20 border border-gray-100 dark:border-zinc-800/40 p-4 rounded-3xl shadow-sm hover:shadow-md transition-all duration-300 transform hover:-translate-y-1";
        card.innerHTML = `
            <div>
              <div class="relative w-full aspect-[4/3] overflow-hidden rounded-2xl mb-4 bg-gray-100 dark:bg-zinc-800">
                <img 
                  src="${property.image}" 
                  alt="${property.name}" 
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out" 
                /> 
                <span class="absolute top-3 left-3 text-[10px] uppercase font-black tracking-widest px-3 py-1 rounded-full ${property.categoryClass} backdrop-blur-md shadow-sm">
                  ${property.category}
                </span>
                <div class="absolute top-3 right-3 bg-white/90 dark:bg-[#1A1A1A]/90 backdrop-blur-sm px-2 py-0.5 rounded-full flex items-center gap-1 shadow-sm">
                  <span class="text-amber-500 text-xs">★</span>
                  <span class="text-[10px] font-black text-dark dark:text-white">4.92</span>
                </div>
              </div>
              <div class="px-1 space-y-1">
                <h3 class="text-base sm:text-lg font-black text-dark dark:text-white truncate">${property.name}</h3>
                <p class="text-gray-500 dark:text-gray-400 text-xs sm:text-sm flex items-center gap-1">
                  <svg class="h-3 w-3 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  ${property.location}
                </p>
                <p class="text-gray-400 dark:text-zinc-500 text-xs line-clamp-3 leading-relaxed pt-1.5 min-h-[3.30rem]">${property.description}</p>
                <p class="font-black text-dark dark:text-white pt-2 text-sm">NRs ${property.price} <span class="font-normal text-gray-500 dark:text-gray-400">/ night</span></p>
              </div>
            </div>
            <div class="px-1 mt-4">
              <button onclick="initiateBooking('${property.id}')" class="w-full bg-brand hover:bg-[#E31C5F] text-white font-extrabold py-3 px-4 rounded-xl flex items-center justify-center gap-2 transition-all active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2 dark:focus:ring-offset-[#121212] select-none text-xs sm:text-sm shadow-md">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span>Book Stay</span>
              </button>
            </div>
          `;
        staysGrid.appendChild(card);
      });
    }

    // Router state navigator
    function navigateTo(viewName) {
      window.scrollTo({ top: 0, behavior: "smooth" });

      homeView.classList.add("hidden");
      heroBanner.classList.add("hidden");
      reserveView.classList.add("hidden");
      successView.classList.add("hidden");
      backToHomeBtn.classList.add("hidden");

      if (viewName === "home") {
        homeView.classList.remove("hidden");
        heroBanner.classList.remove("hidden");
      } else if (viewName === "reserve") {
        reserveView.classList.remove("hidden");
        backToHomeBtn.classList.remove("hidden");
      } else if (viewName === "success") {
        successView.classList.remove("hidden");
      }
    }

    // Populate card parameters into Checkout modules
    function initiateBooking(propertyId) {
      selectedProperty = propertiesDb.find((item) => item.id === propertyId);
      if (!selectedProperty) return;

      summaryImg.src = selectedProperty.image;
      summaryImg.alt = selectedProperty.name;
      summaryName.textContent = selectedProperty.name;
      summaryLoc.textContent = selectedProperty.location;
      summaryCat.textContent = selectedProperty.category;

      // Apply visual category highlights dynamically on checkout page
      summaryCat.className = `text-[10px] uppercase font-extrabold tracking-wider px-2.5 py-0.5 rounded-full inline-block mb-1 ${selectedProperty.categoryClass}`;

      updateBookingPricingCalculation();
      navigateTo("reserve");
    }

    // Realtime Checkout Invoice Calculations
    function updateBookingPricingCalculation() {
      if (!selectedProperty) return;

      const checkInDate = new Date(checkInInput.value);
      const checkOutDate = new Date(checkOutInput.value);

      // Calculate delta nights difference (minimum fallback 1 night)
      let deltaNights = Math.round(
        (checkOutDate - checkInDate) / (1000 * 60 * 60 * 24),
      );
      if (isNaN(deltaNights) || deltaNights <= 0) {
        deltaNights = 1;
      }

      const baselinePriceSum = selectedProperty.price * deltaNights;
      const serviceFee = Math.round(baselinePriceSum * 0.08); // 8% standard service fee
      const taxContribution = Math.round(baselinePriceSum * 0.12); // 12% baseline tourism tax
      const absoluteGrandTotal =
        baselinePriceSum + serviceFee + taxContribution;

      // Populate receipt content elements
      labelNights.textContent = `$${selectedProperty.price} x ${deltaNights} night${deltaNights > 1 ? "s" : ""}`;
      calcNights.textContent = `$${baselinePriceSum}`;
      calcService.textContent = `$${serviceFee}`;
      calcTax.textContent = `$${taxContribution}`;
      calcTotal.textContent = `$${absoluteGrandTotal}`;
    }

    // Live updates upon date alterations
    checkInInput.addEventListener("change", () => {
      const checkInDate = new Date(checkInInput.value);
      const minCheckoutLimit = new Date(checkInDate);
      minCheckoutLimit.setDate(minCheckoutLimit.getDate() + 1);
      checkOutInput.min = minCheckoutLimit.toISOString().split("T")[0];

      if (new Date(checkOutInput.value) <= checkInDate) {
        checkOutInput.value = minCheckoutLimit.toISOString().split("T")[0];
      }
      updateBookingPricingCalculation();
    });

    checkOutInput.addEventListener("change", updateBookingPricingCalculation);

    // Guests Selector triggers
    guestInc.addEventListener("click", () => {
      if (numberOfGuests < 8) {
        numberOfGuests++;
        updateGuestsUI();
      }
    });

    guestDec.addEventListener("click", () => {
      if (numberOfGuests > 1) {
        numberOfGuests--;
        updateGuestsUI();
      }
    });

    function updateGuestsUI() {
      guestVal.textContent = numberOfGuests;
      guestSummaryLabel.textContent = `${numberOfGuests} guest${numberOfGuests > 1 ? "s" : ""}`;
      guestDec.disabled = numberOfGuests === 1;
      guestInc.disabled = numberOfGuests === 8;
    }

    // Credit Card layout auto formatting space loops
    const cardNumberInput = document.getElementById("card-number");
    cardNumberInput.addEventListener("input", (e) => {
      let rawDigitsVal = e.target.value
        .replace(/\s+/g, "")
        .replace(/[^0-9]/gi, "");
      let groupedCardVal = "";
      for (let idx = 0; idx < rawDigitsVal.length; idx++) {
        if (idx > 0 && idx % 4 === 0) {
          groupedCardVal += " ";
        }
        groupedCardVal += rawDigitsVal[idx];
      }
      e.target.value = groupedCardVal;
    });

    // Submit Confirm & Pay Transaction triggers success screen
    confirmBookingBtn.addEventListener("click", () => {
      const cardHolder = document.getElementById("card-holder").value.trim();
      const cardNum = cardNumberInput.value.trim();
      const cardExp = document.getElementById("card-exp").value.trim();
      const cardCVV = document.getElementById("card-cvv").value.trim();

      // Highlighting error borders on unfilled payment fields
      if (!cardHolder || cardNum.length < 15 || !cardExp || !cardCVV) {
        confirmBookingBtn.classList.add("border-2", "border-brand");
        setTimeout(
          () =>
            confirmBookingBtn.classList.remove("border-2", "border-brand"),
          2000,
        );
        return;
      }

      // Generate customized confirmation transaction reference code
      const randomBookingRef =
        "VIBE-" + Math.floor(100000 + Math.random() * 900000);
      const nightsText = labelNights.textContent.split("x")[1].trim();

      receiptRef.textContent = randomBookingRef;
      receiptName.textContent = selectedProperty.name;
      receiptDates.textContent = `${checkInInput.value} to ${checkOutInput.value} (${nightsText})`;
      receiptTotal.textContent = calcTotal.textContent;

      navigateTo("success");
    });

    // Platform View navigation controls
    backToHomeBtn.addEventListener("click", () => navigateTo("home"));
    document
      .getElementById("reserve-back-arrow")
      .addEventListener("click", () => navigateTo("home"));

    // Hamburger dropdown controls
    const menuButton = document.getElementById("menu-button");
    const menuDropdown = document.getElementById("menu-dropdown");

    menuButton.addEventListener("click", (e) => {
      e.stopPropagation();
      menuDropdown.classList.toggle("hidden");
    });

    document.addEventListener("click", () => {
      menuDropdown.classList.add("hidden");
    });

    // Dark Mode toggle scripting logic
    const themeToggleBtn = document.getElementById("theme-toggle");
    const sunIcon = document.getElementById("theme-toggle-sun");
    const moonIcon = document.getElementById("theme-toggle-moon");

    if (document.documentElement.classList.contains("dark")) {
      sunIcon.classList.remove("hidden");
    } else {
      moonIcon.classList.remove("hidden");
    }

    themeToggleBtn.addEventListener("click", function () {
      sunIcon.classList.toggle("hidden");
      moonIcon.classList.toggle("hidden");

      if (document.documentElement.classList.contains("dark")) {
        document.documentElement.classList.remove("dark");
        localStorage.setItem("color-theme", "light");
      } else {
        document.documentElement.classList.add("dark");
        localStorage.setItem("color-theme", "dark");
      }
    });

    // Update copyright footer year dynamically to match 2026
    document.getElementById("current-year").textContent =
      new Date().getFullYear() || "2026";

    // Application initialization
    window.onload = function () {
      renderCuratedCatalog();

      // Setting up standard checkout limits to block yesterday's dates
      const tomorrow = new Date(today);
      tomorrow.setDate(tomorrow.getDate() + 1);
      checkInInput.min = today.toISOString().split("T")[0];
      checkOutInput.min = tomorrow.toISOString().split("T")[0];
    };
  </script>
</body>

</html>