          aria-label="Go Back">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
            stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        </button>

        <!-- Brand Logo -->
        <div onclick="navigateTo('home')"
          class="text-brand font-extrabold text-xl sm:text-2xl tracking-tighter flex items-center gap-1.5 sm:gap-2 cursor-pointer select-none shrink-0">
          <svg class="h-6 w-6 sm:h-8 sm:w-8 text-brand shrink-0" viewBox="0 0 100 100" fill="none"
            xmlns="http://www.w3.org/2000/svg">
            <path d="M15 25L50 85L85 25" stroke="currentColor" stroke-width="12" stroke-linecap="round"
              stroke-linejoin="round" />
            <path d="M35 25L50 55L65 25" stroke="currentColor" stroke-width="8" stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>
          <span class="font-extrabold text-xl sm:text-2xl tracking-tight">vibestay</span>
        </div>
      </div>

      <!-- Search Bar -->
      <div
        class="hidden md:flex items-center border border-gray-200 dark:border-zinc-700 rounded-full shadow-sm hover:shadow-md transition cursor-pointer px-4 py-2 gap-4 bg-white dark:bg-zinc-800 shrink-0">
        <span class="font-semibold text-sm px-2">Anywhere</span>
        <span class="text-gray-300 dark:text-zinc-600">|</span>
        <span class="font-semibold text-sm px-2">Any week</span>
        <span class="text-gray-300 dark:text-zinc-600">|</span>
        <span class="text-gray-500 dark:text-gray-400 text-sm px-2">Add guests</span>
        <div class="bg-brand text-white p-2 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>

      <!-- Right Side Nav: Theme Toggle & Profile Dropdown -->
      <div class="flex items-center gap-2 sm:gap-4 shrink-0">
        <button id="theme-toggle"
          class="p-2 sm:p-2.5 rounded-full border border-gray-200 dark:border-zinc-700 hover:bg-gray-50 dark:hover:bg-zinc-800 text-gray-500 dark:text-gray-400 transition animate-pulse"
          aria-label="Toggle Theme">
          <svg id="theme-toggle-sun" class="hidden h-4.5 w-4.5 sm:h-5 sm:w-5" fill="none" viewBox="0 0 24 24"
            stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <svg id="theme-toggle-moon" class="hidden h-4.5 w-4.5 sm:h-5 sm:w-5" fill="none" viewBox="0 0 24 24"
            stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <!-- Hamburger Button / Menu Dropdown -->
        <div class="relative">
          <button id="menu-button"
            class="border border-gray-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 rounded-full py-1.5 px-2 sm:py-2 sm:px-3 hover:shadow-md transition flex items-center gap-2 sm:gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5 sm:h-5 sm:w-5 text-gray-600 dark:text-gray-300"
              fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <div
              class="bg-gray-400 dark:bg-zinc-600 rounded-full w-5 h-5 sm:w-6 sm:h-6 flex items-center justify-center text-white text-[10px] sm:text-xs font-bold">
              U
            </div>
          </button>

          <!-- Dropdown Menu with relative routes -->
          <div id="menu-dropdown"
            class="hidden absolute right-0 mt-2 w-52 sm:w-60 bg-white dark:bg-zinc-800 border border-gray-100 dark:border-zinc-700 rounded-2xl shadow-xl py-2.5 z-50 transition-all">
            <a href="/host"
              class="block px-4 py-3 text-sm font-semibold text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-zinc-700 transition">Become
              a host</a>
            <hr class="border-gray-100 dark:border-zinc-700 my-1" />
            <a href="/home-list"
              class="block px-4 py-2.5 text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-zinc-700 transition">Home
              Lists</a>
            <a href="/host/host-home-list"
              class="block px-4 py-2.5 text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-zinc-700 transition">Host
              Home Lists</a>
            <a href="/bookings"
              class="block px-4 py-2.5 text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-zinc-700 transition">Booking</a>
            <a href="/favourite-list"
              class="block px-4 py-2.5 text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-zinc-700 transition">Favourite
              List</a>
            <a href="/reserve"
              class="block px-4 py-2.5 text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-zinc-700 transition">Reserve</a>
            <hr class="border-gray-100 dark:border-zinc-700 my-1" />
            <a href="/sign-up"
              class="block px-4 py-2.5 text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-zinc-700 transition">Sign
              up</a>
            <a href="/log-in"
              class="block px-4 py-2.5 text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-zinc-700 transition">Log
              in</a>
            <hr class="border-gray-100 dark:border-zinc-700 my-1" />
            <a href="/help-center"
              class="block px-4 py-2.5 text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-zinc-700 transition">Help
              Center</a>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <!-- SECTION 1: Welcome Hero Section -->
  <section id="hero-banner" class="relative overflow-hidden bg-zinc-900 text-white min-h-[460px] flex items-center">
    <div class="absolute inset-0 z-0">
      <!-- Premium hero wallpaper with deep contrast overlay -->
      <img src="https://images.unsplash.com/photo-1470770841072-f978cf4d019e?auto=format&fit=crop&q=80&w=1600"
        class="w-full h-full object-cover opacity-45 scale-105" alt="Adventure backdrop" />
      <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/60 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-16 w-full text-left">
      <span
        class="inline-flex items-center gap-1.5 px-3.5 py-1 rounded-full bg-brand text-xs font-extrabold uppercase tracking-widest mb-6">
        ✨ Premium Selection 2026
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight leading-none mb-4">
        Discover places<br />that match
        <span class="text-brand">your vibe</span>
      </h1>
      <p class="text-gray-300 max-w-lg text-base sm:text-lg font-medium mb-8 leading-relaxed">
        Escape standard accommodations. Stay in handpicked architect-designed
        domes, nature-woven lofts, and luxurious historic villas.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/home-list"
          class="bg-brand hover:bg-[#E31C5F] text-white font-extrabold py-3.5 px-7 rounded-2xl text-sm transition-all shadow-lg shadow-brand/20 flex items-center gap-2">
          Explore Collection
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
        <a href="/host"
          class="bg-white/15 hover:bg-white/25 border border-white/20 text-white backdrop-blur-sm font-extrabold py-3.5 px-7 rounded-2xl text-sm transition-all">
          List Your Space
        </a>
      </div>
    </div>
  </section>

  <!-- MAIN PLATFORM CATALOG VIEW -->
  <main id="view-home" class="py-12 sm:py-16 px-4 sm:px-6 fade-in">
    <div class="max-w-7xl mx-auto">
      <!-- Category Navigation Row -->
      <div
        class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12 border-b border-gray-100 dark:border-zinc-800 pb-6">
        <div class="text-left">
          <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-dark dark:text-white">
            Featured Spaces
          </h2>
          <p class="text-gray-500 dark:text-gray-400 mt-1 text-sm sm:text-base">
            Curated architectural masterpiece stays worldwide
          </p>
        </div>
        <!-- Category Quicklinks Filter Pills -->
        <div class="flex flex-wrap gap-2.5">
          <a href="/trending"
            class="px-4.5 py-2 rounded-full border border-gray-200 dark:border-zinc-700 hover:border-brand dark:hover:border-brand text-xs font-bold transition flex items-center gap-1.5">
            <span class="h-2 w-2 rounded-full bg-brand"></span> Trending Stays
          </a>
          <a href="/classic-dorms"
            class="px-4.5 py-2 rounded-full border border-gray-200 dark:border-zinc-700 hover:border-brand dark:hover:border-brand text-xs font-bold transition flex items-center gap-1.5">
            <span class="h-2 w-2 rounded-full bg-teal-500"></span> Classic
            Dorms
          </a>
          <a href="/villas"
            class="px-4.5 py-2 rounded-full border border-gray-200 dark:border-zinc-700 hover:border-brand dark:hover:border-brand text-xs font-bold transition flex items-center gap-1.5">
            <span class="h-2 w-2 rounded-full bg-amber-500"></span> Luxury
            Villas
          </a>
        </div>
      </div>

      <!-- Catalog Stays Grid - strictly displaying 3 specific category homes -->
      <div id="stays-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12">
        <!-- Dynamically populated stays from script populate here -->
      </div>
    </div>
  </main>

  <!-- RESERVATION INTERFACE VIEW -->
  <main id="view-reserve" class="hidden py-12 sm:py-16 px-4 sm:px-6 fade-in">
    <div class="max-w-5xl mx-auto">
      <!-- Back Arrow/Title Nav Bar -->
      <div class="flex items-center gap-3.5 mb-10">
        <button id="reserve-back-arrow"
          class="p-2.5 bg-gray-50 dark:bg-zinc-800 rounded-full hover:bg-gray-100 dark:hover:bg-zinc-700 transition shadow-sm border border-gray-100 dark:border-zinc-700/50">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-dark dark:text-white" fill="none"
            viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-dark dark:text-white tracking-tight">
          Confirm and pay
        </h1>
      </div>

      <!-- Layout Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
        <!-- Left Column: Checkout Inputs Form -->
        <div class="lg:col-span-7 space-y-8">
          <!-- Reservation Segment 1: Trip dates and guests details -->
          <div class="border-b border-gray-100 dark:border-zinc-800 pb-8 space-y-6">
            <h2 class="text-xl font-extrabold">Your trip details</h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <!-- Check-in input dates -->
              <div class="flex flex-col gap-1.5">
                <label for="check-in"
                  class="text-xs font-extrabold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Check-in</label>
                <input type="date" id="check-in"
                  class="bg-gray-50 dark:bg-zinc-800 border border-gray-200 dark:border-zinc-700 rounded-2xl px-4 py-3.5 text-sm focus:ring-2 focus:ring-brand focus:border-transparent outline-none font-bold transition" />
              </div>
              <!-- Check-out input dates -->
              <div class="flex flex-col gap-1.5">
                <label for="check-out"
                  class="text-xs font-extrabold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Checkout</label>
                <input type="date" id="check-out"
                  class="bg-gray-50 dark:bg-zinc-800 border border-gray-200 dark:border-zinc-700 rounded-2xl px-4 py-3.5 text-sm focus:ring-2 focus:ring-brand focus:border-transparent outline-none font-bold transition" />
              </div>
            </div>

            <!-- Interactive Guest Counter Selector -->
            <div
              class="bg-gray-50 dark:bg-zinc-800/50 p-4 sm:p-5 rounded-2xl border border-gray-100 dark:border-zinc-800 flex justify-between items-center gap-4">
              <div>
                <h3 class="font-extrabold text-sm sm:text-base">Guests</h3>
                <p id="guest-count-summary" class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">
                  1 guest
                </p>
              </div>
              <!-- Interactive increment widget -->
              <div
                class="flex items-center gap-3.5 bg-white dark:bg-zinc-800 rounded-xl px-3 py-2 border border-gray-200 dark:border-zinc-700 shadow-sm select-none">
                <button id="guest-dec"
                  class="text-gray-500 dark:text-gray-300 hover:text-brand font-black text-lg w-6 h-6 flex items-center justify-center disabled:opacity-30 disabled:pointer-events-none"
                  disabled>
                  -
                </button>
                <span id="guest-val" class="font-extrabold text-sm w-4 text-center">1</span>
                <button id="guest-inc"
                  class="text-gray-500 dark:text-gray-300 hover:text-brand font-black text-lg w-6 h-6 flex items-center justify-center">
                  +
                </button>
              </div>
            </div>
          </div>

          <!-- Reservation Segment 2: Interactive payment interface details -->
          <div class="border-b border-gray-100 dark:border-zinc-800 pb-8 space-y-6">
            <div class="flex items-center justify-between">
              <h2 class="text-xl font-extrabold">Pay with</h2>
              <!-- Visa / MasterCard branding -->
              <div class="flex items-center gap-1.5 text-gray-300 dark:text-zinc-600">
                <span
                  class="text-[10px] font-black px-2 py-0.5 border border-gray-200 dark:border-zinc-700 rounded text-gray-400">VISA</span>
                <span
                  class="text-[10px] font-black px-2 py-0.5 border border-gray-200 dark:border-zinc-700 rounded text-gray-400">MC</span>
              </div>
            </div>

            <!-- Input Payment Form -->
            <div class="space-y-4">
              <div class="relative">
                <input type="text" id="card-holder" placeholder="Name on card" required
                  class="w-full bg-gray-50 dark:bg-zinc-800 border border-gray-200 dark:border-zinc-700 rounded-2xl px-4 py-3.5 text-sm focus:ring-2 focus:ring-brand focus:border-transparent outline-none transition" />
              </div>
              <div class="relative">
                <input type="text" id="card-number" placeholder="Card number" maxlength="19" required
                  class="w-full bg-gray-50 dark:bg-zinc-800 border border-gray-200 dark:border-zinc-700 rounded-2xl px-4 py-3.5 text-sm focus:ring-2 focus:ring-brand focus:border-transparent outline-none transition" />
              </div>
              <div class="grid grid-cols-2 gap-4">
                <input type="text" id="card-exp" placeholder="Expiration (MM/YY)" maxlength="5" required
                  class="bg-gray-50 dark:bg-zinc-800 border border-gray-200 dark:border-zinc-700 rounded-2xl px-4 py-3.5 text-sm focus:ring-2 focus:ring-brand focus:border-transparent outline-none transition" />
                <input type="password" id="card-cvv" placeholder="CVV" maxlength="3" required
                  class="bg-gray-50 dark:bg-zinc-800 border border-gray-200 dark:border-zinc-700 rounded-2xl px-4 py-3.5 text-sm focus:ring-2 focus:ring-brand focus:border-transparent outline-none transition" />
              </div>
            </div>
          </div>

          <!-- Reservation Segment 3: Premium cancellation policy information -->
          <div class="space-y-6">
            <div>
              <h2 class="text-xl font-extrabold mb-2">Cancellation policy</h2>
              <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
                Free cancellation for 48 hours. After that, cancel before
                check-in to get a full refund of the stay price minus the
                service fee.
              </p>
            </div>
            <button id="confirm-booking-btn"
              class="w-full bg-brand hover:bg-[#E31C5F] text-white font-extrabold py-4 px-6 rounded-2xl flex items-center justify-center gap-2.5 transition-all shadow-lg shadow-brand/20 active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2 dark:focus:ring-offset-[#121212] select-none text-base">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24"
                stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <span>Confirm and Pay</span>
            </button>
          </div>
        </div>

        <!-- Right Column: Interactive Sticky Receipt Summary Card -->
        <div class="lg:col-span-5 lg:sticky lg:top-28">
          <div
            class="border border-gray-200 dark:border-zinc-800 bg-white dark:bg-zinc-800/80 rounded-3xl p-6 shadow-xl space-y-6">
            <!-- Selected Home Premium Highlight Header -->
            <div class="flex gap-4 items-center border-b border-gray-100 dark:border-zinc-800/80 pb-6">
              <div class="w-24 h-20 overflow-hidden rounded-xl bg-gray-100 dark:bg-zinc-700 flex-shrink-0">
                <img id="summary-img" src="" alt="" class="w-full h-full object-cover" />
              </div>
              <div class="min-w-0 flex-1">
                <span id="summary-cat"
                  class="text-[10px] uppercase font-extrabold tracking-wider bg-brand/10 text-brand px-2.5 py-0.5 rounded-full inline-block mb-1"></span>
                <h3 id="summary-name" class="font-extrabold text-dark dark:text-white text-base truncate"></h3>
                <p id="summary-loc" class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 truncate"></p>
                <div class="flex items-center gap-1 mt-1">
                  <svg class="h-3.5 w-3.5 text-amber-400 fill-current" viewBox="0 0 20 20">
                    <path
                      d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                  <span class="text-xs font-bold">4.92</span>
                  <span class="text-xs text-gray-400">(48 reviews)</span>
                </div>
              </div>
            </div>

            <!-- Price breakdown details calculations -->
            <div class="space-y-4">
              <h4 class="font-extrabold text-xs uppercase tracking-wider text-gray-400 dark:text-zinc-500">
                Price Details
              </h4>

              <div class="flex justify-between items-center text-sm">
                <span id="label-nights" class="text-gray-600 dark:text-gray-400"></span>
                <span id="calc-nights" class="font-semibold text-dark dark:text-white"></span>
              </div>

              <div class="flex justify-between items-center text-sm">
                <span class="text-gray-600 dark:text-gray-400">VibeStay service fee</span>
                <span id="calc-service" class="font-semibold text-dark dark:text-white"></span>
              </div>

              <div class="flex justify-between items-center text-sm">
                <span class="text-gray-600 dark:text-gray-400">Occupancy taxes</span>
                <span id="calc-tax" class="font-semibold text-dark dark:text-white"></span>
              </div>

              <hr class="border-gray-100 dark:border-zinc-700/80 my-2" />

              <!-- Grand Total Pricing -->
              <div class="flex justify-between items-center">
                <span class="font-extrabold text-base text-dark dark:text-white">Total (USD)</span>
                <span id="calc-total" class="font-black text-2xl text-brand"></span>
              </div>
            </div>

            <!-- Extra value props -->
            <div
              class="bg-gray-50 dark:bg-zinc-800/40 p-4 rounded-xl border border-gray-100 dark:border-zinc-800/80 flex gap-3.5 items-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-500 shrink-0 mt-0.5" fill="none"
                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div class="text-xs space-y-0.5">
                <p class="font-extrabold text-emerald-600 dark:text-emerald-400">
                  VibeStay Protection Included
                </p>
                <p class="text-gray-400 dark:text-zinc-500 leading-relaxed">
                  Every booking includes premium protection from host
                  cancellations, listing inaccuracies, and travel emergencies.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- SECTION 3: Confirmation Success Page View -->
  <main id="view-success" class="hidden py-20 px-4 sm:px-6 slide-up">
    <div
      class="max-w-md mx-auto bg-white dark:bg-zinc-900 border border-gray-100 dark:border-zinc-800 rounded-3xl p-8 shadow-2xl text-center space-y-6">
      <!-- Animated success checkmark -->
      <div
        class="inline-flex items-center justify-center h-20 w-20 rounded-full bg-emerald-50 dark:bg-emerald-950/50 text-emerald-500 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"
          stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <div class="space-y-2">
        <h1 class="text-3xl font-extrabold text-dark dark:text-white">
          Pack your bags!
        </h1>
        <p class="text-emerald-600 dark:text-emerald-400 font-extrabold text-sm uppercase tracking-wider">
          Stay Confirmed
        </p>
      </div>

      <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">
        Your reservation has been completed successfully. Check-in guidelines
        and secure door unlock codes will be emailed shortly.
      </p>

      <!-- Dynamic Invoice Reference Info -->
      <div
        class="bg-gray-50 dark:bg-zinc-800/60 rounded-2xl p-5 text-left divide-y divide-gray-100 dark:divide-zinc-700/80 text-xs">
        <div class="flex justify-between py-3">
          <span class="text-gray-400 font-medium">Booking Reference</span>
          <span id="receipt-ref" class="font-black text-dark dark:text-white"></span>
        </div>
        <div class="flex justify-between py-3">
          <span class="text-gray-400 font-medium">Property Name</span>
          <span id="receipt-name"
            class="font-extrabold text-dark dark:text-white text-right truncate max-w-[200px]"></span>
        </div>
        <div class="flex justify-between py-3">
          <span class="text-gray-400 font-medium">Reservation Dates</span>
          <span id="receipt-dates" class="font-extrabold text-dark dark:text-white"></span>
        </div>
        <div class="flex justify-between py-3">
          <span class="text-gray-400 font-medium">Payment Total</span>
          <span id="receipt-total" class="font-black text-brand text-sm"></span>
        </div>
      </div>

      <div class="pt-4">
        <button onclick="navigateTo('home')"
          class="w-full bg-dark dark:bg-white text-white dark:text-dark font-extrabold py-3.5 rounded-2xl transition hover:opacity-95 text-sm select-none shadow-md">
          Discover more stays
        </button>
      </div>
    </div>
  </main>

  <!-- PREMIUM PLATFORM FOOTER -->
  <footer
    class="border-t border-gray-100 dark:border-zinc-800 bg-gray-50 dark:bg-zinc-900/50 mt-16 py-12 sm:py-16 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <!-- Grid layout for footer columns -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-12 mb-12">
        <!-- Column 1: Brand Pitch -->
        <div class="space-y-4">
          <div
            class="text-brand font-extrabold text-xl tracking-tighter flex items-center gap-1.5 cursor-pointer select-none">
            <svg class="h-6 w-6 text-brand" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M15 25L50 85L85 25" stroke="currentColor" stroke-width="12" stroke-linecap="round"
                stroke-linejoin="round" />
              <path d="M35 25L50 55L65 25" stroke="currentColor" stroke-width="8" stroke-linecap="round"
                stroke-linejoin="round" />
            </svg>
            <span class="font-extrabold tracking-tight">vibestay</span>
          </div>
          <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
            Curating exceptional architectural masterpieces, luxury lofts, and
            classic escapes across the globe. Elevate your destination
            experience.
          </p>
        </div>

        <!-- Column 2: Explore Relative links -->
        <div class="space-y-3.5 text-left">
          <h4 class="text-xs font-black uppercase tracking-widest text-dark dark:text-white">
            Explore
          </h4>
          <ul class="space-y-2 text-xs sm:text-sm">
            <li>
              <a href="/home-list"
                class="text-gray-500 dark:text-gray-400 hover:text-brand dark:hover:text-white transition">All Stay
                Listings</a>
            </li>
            <li>
              <a href="/trending"
                class="text-gray-500 dark:text-gray-400 hover:text-brand dark:hover:text-white transition">Trending
                Escapes</a>
